---

---

<section class='hero cinematic-hero'>
  <div class='hero-bg'></div>
  <div class='hero-overlay'></div>

  <!-- Decorative Elements -->
  <div class='floating-circle circle-1'></div>
  <div class='floating-circle circle-2'></div>
  <div class='hero-spotlight'></div>
  <div class='hero-spotlight-secondary'></div>

  <div class='hero-content container'>
    <div class='hero-text-wrapper'>
      <div class='subtitle-wrapper'>
        <div class='subtitle-line'></div>
        <span class='subtitle'>Psicóloga Clínica de Excelencia</span>
        <div class='subtitle-line'></div>
      </div>

      <h1 class='hero-title'>
        <div class='line'>Maria</div>
        <div class='line'>Alejandra</div>
        <div class='line text-shimmer'>Ruiz</div>
      </h1>

      <div class='hero-desc-wrapper'>
        <p class='hero-desc'>
          Transformando vidas a través de la<br />
          <span class='highlight'>psicología clínica de vanguardia</span>
        </p>

        <div class='hero-stats'>
          <div class='stat-item'>
            <span class='stat-number'>20+</span>
            <span class='stat-label'>Años de Experiencia</span>
          </div>
          <div class='stat-divider'></div>
          <div class='stat-item'>
            <span class='stat-number'>10k+</span>
            <span class='stat-label'>Vidas Transformadas</span>
          </div>
          <div class='stat-divider'></div>
          <div class='stat-item'>
            <span class='stat-number'>5★</span>
            <span class='stat-label'>Reconocimiento</span>
          </div>
        </div>
      </div>
    </div>

    <div class='hero-footer'>
      <div class='scroll-indicator'>
        <span>Descubre más</span>
        <div class='scroll-icon'>
          <div class='scroll-dot'></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cinematic-hero {
    opacity: 0;
    animation: heroReveal 1.2s cubic-bezier(0.4, 0, 0.2, 1) 3.2s forwards;
  }

  @keyframes heroReveal {
    from {
      opacity: 0;
      transform: scale(1.02);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .hero {
    min-height: 100vh;
    width: 100%;
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 6rem 0 4rem;
  }

  .hero-spotlight-secondary {
    position: absolute;
    top: 30%;
    right: 20%;
    width: 500px;
    height: 500px;
    background: radial-gradient(
      circle,
      rgba(212, 175, 55, 0.1) 0%,
      rgba(201, 169, 97, 0.03) 50%,
      transparent 70%
    );
    filter: blur(80px);
    animation: pulse 8s ease-in-out infinite;
    animation-delay: 3s;
    pointer-events: none;
  }

  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
        135deg,
        rgba(10, 10, 15, 0.95) 0%,
        rgba(18, 18, 25, 0.9) 50%,
        rgba(10, 10, 15, 0.95) 100%
      ),
      url("https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?ixlib=rb-4.0.3&auto=format&fit=crop&w=2564&q=80");
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    z-index: -2;
    transform: scale(1.1);
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(
      ellipse at center,
      rgba(10, 10, 15, 0.3) 0%,
      rgba(10, 10, 15, 0.85) 100%
    );
    z-index: -1;
  }

  .hero-spotlight {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 800px;
    height: 800px;
    background: radial-gradient(
      circle,
      rgba(201, 169, 97, 0.15) 0%,
      rgba(201, 169, 97, 0.05) 40%,
      transparent 70%
    );
    filter: blur(100px);
    animation: pulse 6s ease-in-out infinite;
    pointer-events: none;
  }

  .floating-circle {
    position: absolute;
    border: 2px solid rgba(201, 169, 97, 0.2);
    border-radius: 50%;
    pointer-events: none;
  }

  .circle-1 {
    width: 300px;
    height: 300px;
    top: 15%;
    right: 10%;
    animation: rotate 30s linear infinite;
  }

  .circle-2 {
    width: 200px;
    height: 200px;
    bottom: 20%;
    left: 8%;
    animation: rotate 40s linear infinite reverse;
  }

  .hero-content {
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    z-index: 1;
  }

  .hero-text-wrapper {
    margin-top: -3vh;
  }

  .subtitle-wrapper {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
    animation: fadeInUp 1s ease-out 0.2s both;
  }

  .subtitle-line {
    width: 60px;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--gold-primary),
      transparent
    );
  }

  .subtitle {
    display: block;
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 4px;
    font-size: 0.85rem;
    color: var(--gold-primary);
    font-weight: 500;
  }

  .hero-title {
    font-size: clamp(4rem, 12vw, 10rem);
    line-height: 0.9;
    margin-bottom: 3rem;
    letter-spacing: -0.03em;
  }

  .line {
    display: block;
    font-weight: 400;
    color: var(--text-primary);
    animation: fadeInUp 1s ease-out both;
  }

  .line:nth-child(1) {
    animation-delay: 0.3s;
  }

  .line:nth-child(2) {
    animation-delay: 0.5s;
  }

  .line:nth-child(3) {
    animation-delay: 0.7s;
  }

  .text-shimmer {
    background: linear-gradient(
      135deg,
      #ffffff 0%,
      var(--gold-primary) 50%,
      var(--gold-secondary) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    background-size: 200% 200%;
    animation: shimmer 5s ease-in-out infinite;
    text-shadow: 0 0 80px rgba(201, 169, 97, 0.4);
    font-weight: 600;
  }

  .hero-desc-wrapper {
    animation: fadeInUp 1s ease-out 0.9s both;
  }

  .hero-desc {
    font-size: 1.3rem;
    line-height: 1.6;
    max-width: 600px;
    color: var(--text-secondary);
    margin-bottom: 3rem;
    font-weight: 300;
  }

  .highlight {
    color: var(--gold-primary);
    font-weight: 500;
    font-style: italic;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-top: 2rem;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    animation: fadeInUp 1s ease-out 1.2s both;
  }

  .stat-item:nth-child(3) {
    animation-delay: 1.3s;
  }

  .stat-item:nth-child(5) {
    animation-delay: 1.4s;
  }

  .stat-number {
    font-size: 2.5rem;
    font-weight: 700;
    background: linear-gradient(
      135deg,
      var(--gold-primary),
      var(--gold-secondary)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-family: var(--font-heading);
  }

  .stat-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-muted);
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: linear-gradient(
      to bottom,
      transparent,
      var(--gold-primary),
      transparent
    );
  }

  .hero-footer {
    position: absolute;
    bottom: 3rem;
    left: var(--spacing-sm);
    width: 100%;
  }

  .scroll-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    animation: fadeIn 1s ease-out 1.5s both;
  }

  .scroll-indicator span {
    text-transform: uppercase;
    letter-spacing: 3px;
    font-size: 0.7rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .scroll-icon {
    width: 30px;
    height: 50px;
    border: 2px solid rgba(201, 169, 97, 0.3);
    border-radius: 20px;
    display: flex;
    justify-content: center;
    padding-top: 8px;
  }

  .scroll-dot {
    width: 6px;
    height: 6px;
    background: var(--gold-primary);
    border-radius: 50%;
    animation: scrollBounce 2s ease-in-out infinite;
  }

  @keyframes scrollBounce {
    0%,
    100% {
      transform: translateY(0);
      opacity: 1;
    }
    50% {
      transform: translateY(15px);
      opacity: 0.5;
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1);
    }
    50% {
      opacity: 0.8;
      transform: translate(-50%, -50%) scale(1.1);
    }
  }

  @keyframes rotate {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes shimmer {
    0%,
    100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: clamp(3rem, 12vw, 6rem);
    }

    .hero-stats {
      flex-wrap: wrap;
      gap: 1.5rem;
    }

    .stat-number {
      font-size: 2rem;
    }

    .circle-1,
    .circle-2 {
      display: none;
    }

    .subtitle-wrapper {
      flex-direction: column;
      gap: 1rem;
    }

    .subtitle-line {
      width: 40px;
    }
  }
</style>
