---

---

<section
  class='hero cinematic-hero'
  id='hero'
  aria-label='Presentación principal'
>
  <!-- Video de fondo -->
  <div class='hero-video-wrapper' aria-hidden='true'>
    <video
      class='hero-video'
      autoplay
      muted
      loop
      playsinline
      preload='auto'
      poster='data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1920 1080"><rect fill="%230a0a0f" width="1920" height="1080"/></svg>'
    >
      <source
        src='https://videos.pexels.com/video-files/3195394/3195394-uhd_2560_1440_25fps.mp4'
        type='video/mp4'
      />
    </video>
  </div>

  <!-- Capas de overlay cinematográficas -->
  <div class='hero-overlay-gradient' aria-hidden='true'></div>
  <div class='hero-overlay-vignette' aria-hidden='true'></div>

  <!-- Partículas doradas decorativas -->
  <div class='hero-particles' aria-hidden='true'>
    <span class='particle'></span>
    <span class='particle'></span>
    <span class='particle'></span>
    <span class='particle'></span>
    <span class='particle'></span>
    <span class='particle'></span>
  </div>

  <!-- Línea dorada decorativa lateral -->
  <div class='hero-gold-line' aria-hidden='true'></div>

  <div class='hero-content container'>
    <div class='hero-text-wrapper'>
      <!-- Subtítulo con líneas decorativas -->
      <div class='subtitle-wrapper'>
        <div class='subtitle-line-left' aria-hidden='true'></div>
        <span class='subtitle'>Psicóloga Clínica de Excelencia</span>
        <div class='subtitle-line-right' aria-hidden='true'></div>
      </div>

      <!-- Nombre principal -->
      <h1 class='hero-title'>
        <span class='title-line' data-text='Maria'>Maria</span>
        <span class='title-line' data-text='Alejandra'>Alejandra</span>
        <span class='title-line title-accent' data-text='Ruiz'>Ruiz</span>
      </h1>

      <!-- Descripción -->
      <div class='hero-desc-block'>
        <p class='hero-desc'>
          Transformando vidas a través de la
          <span class='desc-highlight'>psicología clínica de vanguardia</span>
        </p>
      </div>

      <!-- Estadísticas -->
      <div class='hero-stats' role='list' aria-label='Logros profesionales'>
        <div class='stat-item' role='listitem'>
          <span class='stat-number' data-value='20'>0</span>
          <span class='stat-suffix'>+</span>
          <span class='stat-label'>Años de Experiencia</span>
        </div>
        <div class='stat-divider' aria-hidden='true'></div>
        <div class='stat-item' role='listitem'>
          <span class='stat-number' data-value='10'>0</span>
          <span class='stat-suffix'>k+</span>
          <span class='stat-label'>Vidas Transformadas</span>
        </div>
        <div class='stat-divider' aria-hidden='true'></div>
        <div class='stat-item' role='listitem'>
          <span class='stat-number' data-value='5'>0</span>
          <span class='stat-suffix'>★</span>
          <span class='stat-label'>Reconocimiento</span>
        </div>
      </div>
    </div>

    <!-- Indicador de scroll -->
    <div class='hero-scroll-cta' aria-hidden='true'>
      <span class='scroll-text'>Descubre más</span>
      <div class='scroll-mouse'>
        <div class='scroll-wheel'></div>
      </div>
      <svg
        class='scroll-arrow'
        width='16'
        height='24'
        viewBox='0 0 16 24'
        fill='none'
      >
        <path
          d='M7.293 23.707a1 1 0 001.414 0l6.364-6.364a1 1 0 00-1.414-1.414L8 21.586l-5.657-5.657a1 1 0 00-1.414 1.414l6.364 6.364zM7 0v23h2V0H7z'
          fill='currentColor'></path>
      </svg>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";

  document.addEventListener("loaderComplete", () => {
    const mm = gsap.matchMedia();

    mm.add("(prefers-reduced-motion: no-preference)", () => {
      const hero = document.querySelector(".cinematic-hero") as HTMLElement;
      if (!hero) return;

      // Timeline principal — secuencia cinematográfica
      const master = gsap.timeline({
        defaults: { ease: "power4.out", duration: 1 },
      });

      // 1. Reveal del hero con zoom-out del video
      master
        .fromTo(
          hero,
          { autoAlpha: 0 },
          { autoAlpha: 1, duration: 0.6, ease: "power2.inOut" },
        )
        .fromTo(
          ".hero-video",
          { scale: 1.3 },
          { scale: 1.05, duration: 2.5, ease: "power2.out" },
          0,
        )

        // 2. Línea dorada lateral se despliega
        .fromTo(
          ".hero-gold-line",
          { scaleY: 0 },
          { scaleY: 1, duration: 1.2, ease: "power3.inOut" },
          0.3,
        )

        // 3. Líneas decorativas del subtítulo se expanden
        .fromTo(
          ".subtitle-line-left",
          { scaleX: 0, transformOrigin: "right center" },
          { scaleX: 1, duration: 0.8, ease: "power3.inOut" },
          0.6,
        )
        .fromTo(
          ".subtitle-line-right",
          { scaleX: 0, transformOrigin: "left center" },
          { scaleX: 1, duration: 0.8, ease: "power3.inOut" },
          0.6,
        )

        // 4. Subtítulo — fade con clip-path reveal
        .fromTo(
          ".subtitle",
          {
            autoAlpha: 0,
            y: 10,
            clipPath: "inset(0 100% 0 0)",
          },
          {
            autoAlpha: 1,
            y: 0,
            clipPath: "inset(0 0% 0 0)",
            duration: 0.9,
            ease: "power3.out",
          },
          0.75,
        )

        // 5. Nombre — líneas con stagger y mask reveal
        .fromTo(
          ".title-line",
          {
            autoAlpha: 0,
            y: 80,
            rotationX: -15,
            transformOrigin: "left bottom",
          },
          {
            autoAlpha: 1,
            y: 0,
            rotationX: 0,
            duration: 1.2,
            stagger: 0.12,
            ease: "power4.out",
          },
          1.0,
        )

        // 6. Descripción con reveal suave
        .fromTo(
          ".hero-desc-block",
          { autoAlpha: 0, y: 30 },
          { autoAlpha: 1, y: 0, duration: 0.9 },
          "-=0.5",
        )

        // 7. Stats — números con counter + fade
        .fromTo(
          ".stat-item",
          { autoAlpha: 0, y: 25, scale: 0.95 },
          {
            autoAlpha: 1,
            y: 0,
            scale: 1,
            stagger: 0.1,
            duration: 0.7,
            ease: "back.out(1.4)",
          },
          "-=0.4",
        )
        .fromTo(
          ".stat-divider",
          { scaleY: 0 },
          { scaleY: 1, stagger: 0.08, duration: 0.5, ease: "power3.inOut" },
          "<0.1",
        )

        // 8. Scroll indicator
        .fromTo(
          ".hero-scroll-cta",
          { autoAlpha: 0, y: 20 },
          { autoAlpha: 1, y: 0, duration: 0.8, ease: "power2.out" },
          "-=0.3",
        )

        // 9. Partículas doradas
        .fromTo(
          ".particle",
          { autoAlpha: 0, scale: 0 },
          {
            autoAlpha: 1,
            scale: 1,
            stagger: { amount: 0.6, from: "random" },
            duration: 0.8,
            ease: "back.out(2)",
          },
          "-=0.8",
        );

      // Animar counter de números
      gsap.utils.toArray<HTMLElement>(".stat-number").forEach((el) => {
        const target = parseInt(el.dataset.value || "0", 10);
        const obj = { val: 0 };
        gsap.to(obj, {
          val: target,
          duration: 2,
          delay: 2.2,
          ease: "power2.out",
          onUpdate: () => {
            el.textContent = Math.round(obj.val).toString();
          },
        });
      });

      // Animaciones continuas — partículas flotando
      gsap.utils.toArray<HTMLElement>(".particle").forEach((p, i) => {
        gsap.to(p, {
          y: gsap.utils.random(-40, 40),
          x: gsap.utils.random(-30, 30),
          duration: gsap.utils.random(3, 6),
          repeat: -1,
          yoyo: true,
          ease: "sine.inOut",
          delay: i * 0.4,
        });
      });

      // Scroll wheel bounce
      gsap.to(".scroll-wheel", {
        y: 8,
        repeat: -1,
        yoyo: true,
        duration: 0.9,
        ease: "power1.inOut",
      });

      // Scroll arrow pulse
      gsap.to(".scroll-arrow", {
        y: 4,
        autoAlpha: 0.4,
        repeat: -1,
        yoyo: true,
        duration: 1.2,
        ease: "sine.inOut",
      });

      // Parallax sutil del video al hacer scroll
      gsap.to(".hero-video", {
        y: 100,
        ease: "none",
        scrollTrigger: {
          trigger: ".cinematic-hero",
          start: "top top",
          end: "bottom top",
          scrub: 1,
        },
      });

      // Fade out del contenido al scrollear
      gsap.to(".hero-content", {
        autoAlpha: 0,
        y: -60,
        ease: "none",
        scrollTrigger: {
          trigger: ".cinematic-hero",
          start: "60% top",
          end: "bottom top",
          scrub: 1,
        },
      });
    });

    // Reduced motion: mostrar todo inmediatamente sin animaciones
    mm.add("(prefers-reduced-motion: reduce)", () => {
      gsap.set(
        ".cinematic-hero, .subtitle-line-left, .subtitle-line-right, .subtitle, .title-line, .hero-desc-block, .stat-item, .stat-divider, .hero-scroll-cta, .particle, .hero-gold-line",
        {
          autoAlpha: 1,
          y: 0,
          x: 0,
          scale: 1,
          scaleX: 1,
          scaleY: 1,
          rotationX: 0,
          clipPath: "none",
        },
      );

      // Mostrar valores finales de los counters
      gsap.utils.toArray<HTMLElement>(".stat-number").forEach((el) => {
        el.textContent = el.dataset.value || "0";
      });
    });
  });
</script>

<style>
  /* === BASE === */
  .cinematic-hero {
    visibility: hidden;
    min-height: 100vh;
    width: 100%;
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* === VIDEO DE FONDO === */
  .hero-video-wrapper {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    will-change: transform;
  }

  /* === OVERLAYS === */
  .hero-overlay-gradient {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(10, 10, 15, 0.6) 0%,
      rgba(10, 10, 15, 0.4) 30%,
      rgba(10, 10, 15, 0.5) 60%,
      rgba(10, 10, 15, 0.95) 100%
    );
  }

  .hero-overlay-vignette {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: radial-gradient(
      ellipse at 30% 50%,
      transparent 0%,
      rgba(10, 10, 15, 0.5) 70%,
      rgba(10, 10, 15, 0.8) 100%
    );
  }

  /* === LÍNEA DORADA LATERAL === */
  .hero-gold-line {
    position: absolute;
    left: 5%;
    top: 15%;
    width: 2px;
    height: 70%;
    background: linear-gradient(
      to bottom,
      transparent,
      var(--gold-primary),
      var(--gold-secondary),
      transparent
    );
    z-index: 3;
    transform-origin: top center;
    opacity: 0.6;
  }

  /* === PARTÍCULAS DORADAS === */
  .hero-particles {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
  }

  .particle {
    position: absolute;
    width: 4px;
    height: 4px;
    background: var(--gold-primary);
    border-radius: 50%;
    box-shadow:
      0 0 12px var(--gold-glow),
      0 0 24px rgba(201, 169, 97, 0.2);
  }

  .particle:nth-child(1) {
    top: 20%;
    left: 15%;
    width: 3px;
    height: 3px;
  }
  .particle:nth-child(2) {
    top: 60%;
    left: 80%;
    width: 5px;
    height: 5px;
  }
  .particle:nth-child(3) {
    top: 35%;
    left: 65%;
    width: 3px;
    height: 3px;
  }
  .particle:nth-child(4) {
    top: 75%;
    left: 25%;
    width: 4px;
    height: 4px;
  }
  .particle:nth-child(5) {
    top: 15%;
    left: 85%;
    width: 3px;
    height: 3px;
  }
  .particle:nth-child(6) {
    top: 50%;
    left: 45%;
    width: 5px;
    height: 5px;
  }

  /* === CONTENIDO === */
  .hero-content {
    position: relative;
    z-index: 5;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 100vh;
    padding: 8rem 0 4rem;
  }

  .hero-text-wrapper {
    max-width: 900px;
  }

  /* === SUBTÍTULO === */
  .subtitle-wrapper {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .subtitle-line-left,
  .subtitle-line-right {
    height: 1px;
    width: 60px;
    background: linear-gradient(90deg, transparent, var(--gold-primary));
  }

  .subtitle-line-right {
    background: linear-gradient(90deg, var(--gold-primary), transparent);
  }

  .subtitle {
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 5px;
    font-size: 0.8rem;
    color: var(--gold-primary);
    font-weight: 500;
    white-space: nowrap;
  }

  /* === TÍTULO === */
  .hero-title {
    font-size: clamp(3.8rem, 11vw, 9.5rem);
    line-height: 0.92;
    margin-bottom: 2.5rem;
    letter-spacing: -0.03em;
  }

  .title-line {
    display: block;
    font-weight: 300;
    color: var(--text-primary);
    will-change: transform;
  }

  .title-accent {
    font-weight: 600;
    background: linear-gradient(
      135deg,
      #ffffff 0%,
      var(--gold-primary) 40%,
      var(--gold-secondary) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    background-size: 200% 200%;
    animation: shimmer 6s ease-in-out infinite;
  }

  /* === DESCRIPCIÓN === */
  .hero-desc-block {
    margin-bottom: 2.5rem;
  }

  .hero-desc {
    font-size: 1.25rem;
    line-height: 1.7;
    max-width: 560px;
    color: var(--text-secondary);
    font-weight: 300;
    margin-bottom: 0;
  }

  .desc-highlight {
    color: var(--gold-primary);
    font-weight: 500;
    font-style: italic;
    position: relative;
  }

  /* === ESTADÍSTICAS === */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    position: relative;
  }

  .stat-number {
    font-size: 2.8rem;
    font-weight: 700;
    line-height: 1;
    background: linear-gradient(
      135deg,
      var(--gold-primary),
      var(--gold-secondary)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-family: var(--font-heading);
    display: inline;
  }

  .stat-suffix {
    font-size: 2rem;
    font-weight: 600;
    background: linear-gradient(
      135deg,
      var(--gold-primary),
      var(--gold-secondary)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-family: var(--font-heading);
    line-height: 1;
    margin-top: -0.2rem;
  }

  .stat-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-muted);
    font-weight: 500;
  }

  .stat-divider {
    width: 1px;
    height: 48px;
    background: linear-gradient(
      to bottom,
      transparent,
      var(--gold-primary),
      transparent
    );
    transform-origin: center top;
  }

  /* === SCROLL CTA === */
  .hero-scroll-cta {
    position: absolute;
    bottom: 3rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
  }

  .scroll-text {
    text-transform: uppercase;
    letter-spacing: 3px;
    font-size: 0.65rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .scroll-mouse {
    width: 26px;
    height: 42px;
    border: 2px solid rgba(201, 169, 97, 0.35);
    border-radius: 14px;
    display: flex;
    justify-content: center;
    padding-top: 8px;
  }

  .scroll-wheel {
    width: 4px;
    height: 8px;
    background: var(--gold-primary);
    border-radius: 4px;
  }

  .scroll-arrow {
    color: rgba(201, 169, 97, 0.4);
    width: 12px;
    margin-top: -4px;
  }

  /* === ANIMACIONES CSS === */
  @keyframes shimmer {
    0%,
    100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  /* === RESPONSIVE === */
  @media (max-width: 768px) {
    .hero-content {
      padding: 6rem 0 3rem;
    }

    .hero-title {
      font-size: clamp(2.8rem, 13vw, 5.5rem);
    }

    .hero-stats {
      flex-wrap: wrap;
      gap: 1.5rem;
    }

    .stat-number {
      font-size: 2rem;
    }

    .stat-suffix {
      font-size: 1.4rem;
    }

    .subtitle-wrapper {
      gap: 0.8rem;
    }

    .subtitle {
      letter-spacing: 3px;
      font-size: 0.7rem;
    }

    .subtitle-line-left,
    .subtitle-line-right {
      width: 30px;
    }

    .hero-gold-line {
      left: 3%;
      opacity: 0.4;
    }

    .hero-desc {
      font-size: 1.05rem;
    }

    .particle:nth-child(3),
    .particle:nth-child(5) {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .subtitle-line-left,
    .subtitle-line-right {
      display: none;
    }

    .subtitle-wrapper {
      justify-content: center;
    }

    .hero-gold-line {
      display: none;
    }

    .stat-divider {
      display: none;
    }

    .hero-stats {
      justify-content: center;
      text-align: center;
    }
  }
</style>
