---

---

<section class='conf-section' aria-labelledby='conf-heading'>
  <!-- Video Background -->
  <div class='conf-video-bg' aria-hidden='true'>
    <video
      autoplay
      muted
      loop
      playsinline
      preload='metadata'
      class='conf-video'
    >
      <source
        src='https://videos.pexels.com/video-files/3129671/3129671-uhd_2560_1440_30fps.mp4'
        type='video/mp4'
      />
    </video>
    <div class='conf-video-overlay'></div>
  </div>

  <!-- Horizontal scroll wrapper -->
  <div class='conf-viewport'>
    <div class='conf-track'>
      <!-- Slide 1: Hero / Intro -->
      <div class='conf-slide conf-slide--intro'>
        <div class='slide-content'>
          <span class='conf-label'>Servicios Profesionales</span>
          <h2 id='conf-heading' class='conf-title'>
            Conferencias <span class='amp'>&</span>
            <br />Talleres
          </h2>
          <div class='conf-line' aria-hidden='true'></div>
          <p class='conf-subtitle'>
            Experiencias transformadoras que inspiran el cambio personal y
            organizacional
          </p>
        </div>
      </div>

      <!-- Slide 2: Conferencias -->
      <div class='conf-slide conf-slide--talks'>
        <div class='slide-content'>
          <div class='service-card service-card--glass'>
            <span class='service-icon'>
              <svg
                width='32'
                height='32'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='1.5'
                ><path d='M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z'></path><path
                  d='M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z'></path></svg
              >
            </span>
            <h3 class='service-title'>Conferencias</h3>
            <p class='service-desc'>
              Charlas magistrales sobre salud mental, inteligencia emocional y
              desarrollo personal para audiencias corporativas y académicas.
            </p>
            <ul class='service-features'>
              <li>Keynote Corporativo</li>
              <li>Salud Mental Organizacional</li>
              <li>Liderazgo Consciente</li>
              <li>Inteligencia Emocional</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Slide 3: Talleres -->
      <div class='conf-slide conf-slide--workshops'>
        <div class='slide-content'>
          <div class='service-card service-card--glass'>
            <span class='service-icon'>
              <svg
                width='32'
                height='32'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='1.5'
                ><path d='M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2'
                ></path><circle cx='9' cy='7' r='4'></circle><path
                  d='M23 21v-2a4 4 0 0 0-3-3.87'></path><path
                  d='M16 3.13a4 4 0 0 1 0 7.75'></path></svg
              >
            </span>
            <h3 class='service-title'>Talleres</h3>
            <p class='service-desc'>
              Sesiones interactivas y prácticas diseñadas para equipos y
              comunidades que buscan herramientas concretas de bienestar.
            </p>
            <ul class='service-features'>
              <li>Manejo del Estrés</li>
              <li>Comunicación Asertiva</li>
              <li>Mindfulness Aplicado</li>
              <li>Resiliencia Personal</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Slide 4: CTA -->
      <div class='conf-slide conf-slide--cta'>
        <div class='slide-content'>
          <h3 class='cta-heading'>
            ¿Listo para transformar <br />tu organización?
          </h3>
          <p class='cta-text'>
            Conversemos sobre cómo podemos crear una experiencia a la medida de
            tus necesidades.
          </p>
          <a
            href='https://wa.me/18135686424?text=Hola%20Dra.%20Ruiz%2C%20me%20interesa%20información%20sobre%20conferencias%20y%20talleres.'
            target='_blank'
            rel='noopener noreferrer'
            class='cta-whatsapp'
          >
            <svg
              width='22'
              height='22'
              viewBox='0 0 24 24'
              fill='currentColor'
              aria-hidden='true'
            >
              <path
                d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z'
              ></path>
            </svg>
            <span>Agenda tu evento</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Horizontal scroll indicator -->
    <div class='conf-scroll-hint' aria-hidden='true'>
      <div class='scroll-track'>
        <div class='scroll-progress'></div>
      </div>
      <span class='scroll-label'>Desliza para explorar</span>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { Observer } from "gsap/Observer";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger, Observer);

  let hasAnimated = false;
  let observer: ReturnType<typeof Observer.create> | null = null;

  const animateConferences = () => {
    if (hasAnimated) return;
    hasAnimated = true;

    const track = document.querySelector(".conf-track") as HTMLElement;
    const slides = gsap.utils.toArray<HTMLElement>(".conf-slide");
    const progress = document.querySelector(".scroll-progress") as HTMLElement;
    const viewport = document.querySelector(".conf-viewport") as HTMLElement;

    if (!track || slides.length === 0 || !viewport) return;

    let currentSlide = 0;
    let isSliding = false;
    const totalSlides = slides.length;

    const mm = gsap.matchMedia();

    mm.add("(prefers-reduced-motion: no-preference)", () => {
      // Entrance animation
      const entranceTl = gsap.timeline({
        defaults: { ease: "power3.out" },
      });

      entranceTl
        .fromTo(
          ".conf-label",
          { autoAlpha: 0, y: 20 },
          { autoAlpha: 1, y: 0, duration: 0.8 },
        )
        .fromTo(
          ".conf-title",
          { autoAlpha: 0, y: 40 },
          { autoAlpha: 1, y: 0, duration: 1 },
          0.15,
        )
        .fromTo(
          ".conf-line",
          { scaleX: 0 },
          { scaleX: 1, duration: 0.8, ease: "power3.inOut" },
          0.3,
        )
        .fromTo(
          ".conf-subtitle",
          { autoAlpha: 0, y: 20 },
          { autoAlpha: 1, y: 0, duration: 0.8 },
          0.5,
        )
        .fromTo(
          ".conf-scroll-hint",
          { autoAlpha: 0, y: 10 },
          { autoAlpha: 1, y: 0, duration: 0.6 },
          0.7,
        );

      // Function to go to a specific slide
      const goToSlide = (index: number) => {
        if (isSliding || index === currentSlide) return;
        if (index < 0 || index >= totalSlides) return;
        isSliding = true;

        const direction = index > currentSlide ? 1 : -1;

        gsap.to(track, {
          xPercent: -index * 100,
          duration: 0.8,
          ease: "power3.inOut",
          onComplete: () => {
            currentSlide = index;
            isSliding = false;
          },
        });

        // Animate progress bar
        gsap.to(progress, {
          scaleX: (index + 1) / totalSlides,
          duration: 0.8,
          ease: "power3.inOut",
        });

        // Animate entering slide content
        const targetSlide = slides[index];
        const content = targetSlide.querySelector(".slide-content");
        if (content) {
          gsap.fromTo(
            content,
            { autoAlpha: 0.5, x: direction * 60 },
            {
              autoAlpha: 1,
              x: 0,
              duration: 0.7,
              ease: "power3.out",
              delay: 0.15,
            },
          );
        }
      };

      // Set initial progress
      gsap.set(progress, { scaleX: 1 / totalSlides, transformOrigin: "left" });

      // Observer for horizontal navigation (wheel, touch, pointer)
      observer = Observer.create({
        target: viewport,
        type: "wheel,touch,pointer",
        wheelSpeed: -1,
        onUp: () => goToSlide(currentSlide + 1),
        onDown: () => goToSlide(currentSlide - 1),
        onLeft: () => goToSlide(currentSlide + 1),
        onRight: () => goToSlide(currentSlide - 1),
        tolerance: 50,
        preventDefault: true,
      });

      // Keyboard within section
      viewport.addEventListener("keydown", (e: KeyboardEvent) => {
        if (e.key === "ArrowRight" || e.key === "ArrowDown") {
          e.preventDefault();
          e.stopPropagation();
          goToSlide(currentSlide + 1);
        } else if (e.key === "ArrowLeft" || e.key === "ArrowUp") {
          e.preventDefault();
          e.stopPropagation();
          goToSlide(currentSlide - 1);
        }
      });
    });

    mm.add("(prefers-reduced-motion: reduce)", () => {
      gsap.set(
        ".conf-label, .conf-title, .conf-line, .conf-subtitle, .conf-scroll-hint",
        { autoAlpha: 1, y: 0, scaleX: 1 },
      );
      gsap.set(progress, {
        scaleX: 1 / totalSlides,
        transformOrigin: "left",
      });
    });
  };

  // Clean up observer when leaving section
  document.addEventListener("sectionChanged", ((e: CustomEvent) => {
    if (e.detail.section !== "conferences" && observer) {
      observer.disable();
    } else if (e.detail.section === "conferences" && observer) {
      observer.enable();
    }
  }) as EventListener);

  document.addEventListener("sectionEnter", ((e: CustomEvent) => {
    if (e.detail.section === "conferences") animateConferences();
  }) as EventListener);
</script>

<style>
  .conf-section {
    position: relative;
    height: 100%;
    overflow: hidden;
  }

  /* ── Video Background ── */
  .conf-video-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .conf-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .conf-video-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(10, 10, 15, 0.88) 0%,
      rgba(18, 18, 26, 0.82) 50%,
      rgba(10, 10, 15, 0.92) 100%
    );
    z-index: 1;
  }

  /* ── Viewport (no vertical scroll) ── */
  .conf-viewport {
    position: relative;
    z-index: 2;
    height: 100%;
    overflow: hidden;
    outline: none;
  }

  /* ── Horizontal Track ── */
  .conf-track {
    display: flex;
    height: 100%;
    will-change: transform;
  }

  .conf-slide {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem clamp(1.5rem, 5vw, 6rem) calc(var(--nav-height) + 2rem);
  }

  .slide-content {
    max-width: 600px;
    width: 100%;
  }

  /* ── Slide 1: Intro ── */
  .conf-label {
    display: inline-block;
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--gold-primary);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.45rem 1.2rem;
    background: linear-gradient(
      135deg,
      rgba(201, 169, 97, 0.12),
      rgba(201, 169, 97, 0.05)
    );
    border: 1px solid rgba(201, 169, 97, 0.2);
    border-radius: 30px;
    margin-bottom: 1.5rem;
  }

  .conf-title {
    font-family: var(--font-heading);
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    font-weight: 300;
    line-height: 1.1;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
  }

  .amp {
    background: linear-gradient(
      135deg,
      var(--gold-primary),
      var(--gold-secondary)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-style: italic;
  }

  .conf-line {
    width: 80px;
    height: 1px;
    background: linear-gradient(
      90deg,
      var(--gold-primary),
      var(--gold-secondary),
      transparent
    );
    margin-bottom: 1.5rem;
    transform-origin: left;
  }

  .conf-subtitle {
    font-size: clamp(0.95rem, 1.8vw, 1.15rem);
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 480px;
  }

  /* ── Service Cards ── */
  .service-card--glass {
    padding: 2.5rem;
    border-radius: var(--radius-xl);
    background: linear-gradient(
      145deg,
      rgba(18, 18, 26, 0.7),
      rgba(25, 25, 35, 0.5)
    );
    border: 1px solid rgba(201, 169, 97, 0.12);
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
    box-shadow:
      0 0 0 1px rgba(201, 169, 97, 0.06),
      0 20px 60px rgba(0, 0, 0, 0.4);
  }

  .service-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background: linear-gradient(
      135deg,
      rgba(201, 169, 97, 0.15),
      rgba(201, 169, 97, 0.05)
    );
    border: 1px solid rgba(201, 169, 97, 0.2);
    color: var(--gold-primary);
    margin-bottom: 1.5rem;
  }

  .service-title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 400;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .service-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .service-features {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.7rem;
  }

  .service-features li {
    font-size: 0.82rem;
    color: var(--text-secondary);
    padding-left: 1.2rem;
    position: relative;
  }

  .service-features li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--gold-primary);
    box-shadow: 0 0 8px rgba(201, 169, 97, 0.4);
  }

  /* ── Slide 4: CTA ── */
  .conf-slide--cta .slide-content {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta-heading {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 300;
    color: var(--text-primary);
    line-height: 1.2;
    margin-bottom: 1.2rem;
  }

  .cta-text {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 420px;
    margin-bottom: 2.5rem;
  }

  .cta-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1rem 2.5rem;
    border-radius: 50px;
    background: linear-gradient(135deg, #25d366, #128c7e);
    color: #fff;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow:
      0 4px 20px rgba(37, 211, 102, 0.3),
      0 0 0 1px rgba(37, 211, 102, 0.15);
    position: relative;
    overflow: hidden;
  }

  .cta-whatsapp::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.15), transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
    border-radius: 50px;
  }

  .cta-whatsapp:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow:
      0 8px 30px rgba(37, 211, 102, 0.4),
      0 0 0 1px rgba(37, 211, 102, 0.3);
  }

  .cta-whatsapp:hover::before {
    opacity: 1;
  }

  .cta-whatsapp:focus-visible {
    outline: 2px solid #25d366;
    outline-offset: 3px;
  }

  /* ── Scroll Hint ── */
  .conf-scroll-hint {
    position: absolute;
    bottom: calc(var(--nav-height) + 1.5rem);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    z-index: 5;
  }

  .scroll-track {
    width: 120px;
    height: 2px;
    background: rgba(201, 169, 97, 0.15);
    border-radius: 2px;
    overflow: hidden;
  }

  .scroll-progress {
    height: 100%;
    width: 100%;
    background: linear-gradient(
      90deg,
      var(--gold-primary),
      var(--gold-secondary)
    );
    border-radius: 2px;
    transform-origin: left;
    transform: scaleX(0.25);
  }

  .scroll-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-muted);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .service-card--glass {
      padding: 1.8rem;
    }

    .service-features {
      grid-template-columns: 1fr;
    }

    .cta-whatsapp {
      padding: 0.9rem 2rem;
      font-size: 0.78rem;
    }
  }
</style>
