---
const podcast1 = {
  title: "Dilo Como Es",
  description:
    '"Dilo Como Es" es un innovador podcast show donde María Alejandra, Dra. en psicología clínica, y Lily Taveras, reconocida influencer y actriz, se unen para ofrecer una mirada honesta y sincera sobre los complejos temas de las relaciones, rupturas y autoestima. Con la combinación perfecta de sabiduría profesional y autenticidad, cada episodio es un espacio donde la sinceridad se encuentra con la comprensión, creando una comunidad de apoyo y crecimiento personal.',
};

const podcast2 = {
  title: "Canal Oficial Dra. Ruiz",
  description:
    "El canal oficial de la Dra. Maria Alejandra Ruiz en YouTube: contenido gratuito con conversaciones, reflexiones y herramientas prácticas sobre salud mental y bienestar emocional. Un espacio para conectar con el equipo de la Dra. Ruiz y acceder a recursos que te acompañen en tu proceso de crecimiento personal.",
};
---

<section class='pod-section' aria-labelledby='pod-heading'>
  <!-- Background -->
  <div class='pod-bg' aria-hidden='true'>
    <div class='pod-bg-orb pod-bg-orb--1'></div>
    <div class='pod-bg-orb pod-bg-orb--2'></div>
  </div>

  <!-- Horizontal slides -->
  <div class='pod-viewport' tabindex='0'>
    <div class='pod-track'>
      <!-- Slide 1: Intro -->
      <div class='pod-slide pod-slide--intro'>
        <div class='pslide-content'>
          <span class='pod-label'>Escúchame</span>
          <h2 id='pod-heading' class='pod-title'>
            Podcast <span class='pod-amp'>&</span>
            <br />Media
          </h2>
          <div class='pod-line' aria-hidden='true'></div>
          <p class='pod-subtitle'>
            Conversaciones honestas sobre salud mental, relaciones y bienestar
            emocional
          </p>
        </div>
      </div>

      <!-- Slide 2: Spotify -->
      <div class='pod-slide pod-slide--spotify'>
        <div class='pslide-content'>
          <div class='pod-card pod-card--glass'>
            <div class='pod-card-header'>
              <span class='pod-icon pod-icon--spotify'>
                <svg viewBox='0 0 24 24' fill='currentColor'>
                  <path
                    d='M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z'
                  ></path>
                </svg>
              </span>
              <div>
                <h3 class='pod-card-title'>{podcast1.title}</h3>
                <p class='pod-card-platform'>Spotify Original</p>
              </div>
            </div>
            <div class='pod-embed pod-embed--spotify'>
              <iframe
                title='Podcast de la Dra. Maria Alejandra Ruiz en Spotify'
                style='border-radius:12px'
                src='https://open.spotify.com/embed/show/7EAPPcMUumoRKNNJd44f6k/video?utm_source=generator'
                width='100%'
                height='352'
                allowfullscreen=''
                allow='autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture'
                loading='lazy'></iframe>
            </div>
            <p class='pod-card-desc'>{podcast1.description}</p>
          </div>
        </div>
      </div>

      <!-- Slide 3: YouTube -->
      <div class='pod-slide pod-slide--youtube'>
        <div class='pslide-content'>
          <div class='pod-card pod-card--glass'>
            <div class='pod-card-header'>
              <span class='pod-icon pod-icon--youtube'>
                <svg viewBox='0 0 24 24' fill='currentColor'>
                  <path
                    d='M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z'
                  ></path>
                </svg>
              </span>
              <div>
                <h3 class='pod-card-title'>{podcast2.title}</h3>
                <p class='pod-card-platform'>YouTube Series</p>
              </div>
            </div>
            <div class='pod-embed pod-embed--youtube'>
              <iframe
                width='100%'
                height='352'
                src='https://www.youtube.com/embed/-XgVfoCTgGQ?si=2SrFO0vHnrQEl-Um'
                title='Serie Dilo Como Es en YouTube'
                allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share'
                referrerpolicy='strict-origin-when-cross-origin'
                allowfullscreen
                loading='lazy'
                style='border-radius:12px'></iframe>
            </div>
            <p class='pod-card-desc'>{podcast2.description}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Progress indicator -->
    <div class='pod-scroll-hint' aria-hidden='true'>
      <div class='pod-scroll-track'>
        <div class='pod-scroll-progress'></div>
      </div>
      <span class='pod-scroll-label'>Desliza para explorar</span>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { Observer } from "gsap/Observer";

  gsap.registerPlugin(Observer);

  let hasAnimated = false;
  let observer: ReturnType<typeof Observer.create> | null = null;

  const animatePodcasts = () => {
    if (hasAnimated) return;
    hasAnimated = true;

    const track = document.querySelector(".pod-track") as HTMLElement;
    const slides = gsap.utils.toArray<HTMLElement>(".pod-slide");
    const progress = document.querySelector(
      ".pod-scroll-progress",
    ) as HTMLElement;
    const viewport = document.querySelector(".pod-viewport") as HTMLElement;

    if (!track || slides.length === 0 || !viewport) return;

    let currentSlide = 0;
    let isSliding = false;
    const totalSlides = slides.length;

    const mm = gsap.matchMedia();

    mm.add("(prefers-reduced-motion: no-preference)", () => {
      // Entrance animation
      const entranceTl = gsap.timeline({
        defaults: { ease: "power3.out" },
      });

      entranceTl
        .fromTo(
          ".pod-label",
          { autoAlpha: 0, y: 20 },
          { autoAlpha: 1, y: 0, duration: 0.8 },
        )
        .fromTo(
          ".pod-title",
          { autoAlpha: 0, y: 40 },
          { autoAlpha: 1, y: 0, duration: 1 },
          0.15,
        )
        .fromTo(
          ".pod-line",
          { scaleX: 0 },
          { scaleX: 1, duration: 0.8, ease: "power3.inOut" },
          0.3,
        )
        .fromTo(
          ".pod-subtitle",
          { autoAlpha: 0, y: 20 },
          { autoAlpha: 1, y: 0, duration: 0.8 },
          0.5,
        )
        .fromTo(
          ".pod-scroll-hint",
          { autoAlpha: 0, y: 10 },
          { autoAlpha: 1, y: 0, duration: 0.6 },
          0.7,
        );

      // Slide navigation
      const goToSlide = (index: number) => {
        if (isSliding || index === currentSlide) return;
        if (index < 0 || index >= totalSlides) return;
        isSliding = true;

        const direction = index > currentSlide ? 1 : -1;

        gsap.to(track, {
          xPercent: -index * 100,
          duration: 0.8,
          ease: "power3.inOut",
          onComplete: () => {
            currentSlide = index;
            isSliding = false;
          },
        });

        gsap.to(progress, {
          scaleX: (index + 1) / totalSlides,
          duration: 0.8,
          ease: "power3.inOut",
        });

        // Animate entering slide content
        const targetSlide = slides[index];
        const content = targetSlide.querySelector(".pslide-content");
        if (content) {
          gsap.fromTo(
            content,
            { autoAlpha: 0.5, x: direction * 60 },
            {
              autoAlpha: 1,
              x: 0,
              duration: 0.7,
              ease: "power3.out",
              delay: 0.15,
            },
          );
        }
      };

      // Set initial progress
      gsap.set(progress, {
        scaleX: 1 / totalSlides,
        transformOrigin: "left",
      });

      // Observer for horizontal navigation
      observer = Observer.create({
        target: viewport,
        type: "wheel,touch,pointer",
        wheelSpeed: -1,
        onUp: () => goToSlide(currentSlide + 1),
        onDown: () => goToSlide(currentSlide - 1),
        onLeft: () => goToSlide(currentSlide + 1),
        onRight: () => goToSlide(currentSlide - 1),
        tolerance: 50,
        preventDefault: true,
      });

      // Keyboard navigation
      viewport.addEventListener("keydown", (e: KeyboardEvent) => {
        if (e.key === "ArrowRight" || e.key === "ArrowDown") {
          e.preventDefault();
          e.stopPropagation();
          goToSlide(currentSlide + 1);
        } else if (e.key === "ArrowLeft" || e.key === "ArrowUp") {
          e.preventDefault();
          e.stopPropagation();
          goToSlide(currentSlide - 1);
        }
      });
    });

    mm.add("(prefers-reduced-motion: reduce)", () => {
      gsap.set(
        ".pod-label, .pod-title, .pod-line, .pod-subtitle, .pod-scroll-hint",
        { autoAlpha: 1, y: 0, scaleX: 1 },
      );
      gsap.set(progress, {
        scaleX: 1 / totalSlides,
        transformOrigin: "left",
      });
    });
  };

  // Enable/disable observer on section change
  document.addEventListener("sectionChanged", ((e: CustomEvent) => {
    if (e.detail.section !== "podcasts" && observer) {
      observer.disable();
    } else if (e.detail.section === "podcasts" && observer) {
      observer.enable();
    }
  }) as EventListener);

  document.addEventListener("sectionEnter", ((e: CustomEvent) => {
    if (e.detail.section === "podcasts") animatePodcasts();
  }) as EventListener);
</script>

<style>
  .pod-section {
    position: relative;
    height: 100%;
    overflow: hidden;
  }

  /* ── Background ── */
  .pod-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(
      160deg,
      rgba(10, 10, 15, 1) 0%,
      rgba(18, 18, 26, 0.95) 50%,
      rgba(10, 10, 15, 1) 100%
    );
  }

  .pod-bg-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    pointer-events: none;
  }

  .pod-bg-orb--1 {
    width: 600px;
    height: 600px;
    top: 20%;
    left: -10%;
    background: radial-gradient(
      circle,
      rgba(201, 169, 97, 0.1) 0%,
      transparent 70%
    );
  }

  .pod-bg-orb--2 {
    width: 500px;
    height: 500px;
    bottom: 10%;
    right: -5%;
    background: radial-gradient(
      circle,
      rgba(201, 169, 97, 0.06) 0%,
      transparent 70%
    );
  }

  /* ── Viewport ── */
  .pod-viewport {
    position: relative;
    z-index: 2;
    height: 100%;
    overflow: hidden;
    outline: none;
  }

  /* ── Horizontal Track ── */
  .pod-track {
    display: flex;
    height: 100%;
    will-change: transform;
  }

  .pod-slide {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem clamp(1.5rem, 5vw, 6rem) calc(var(--nav-height) + 2rem);
  }

  .pslide-content {
    max-width: 600px;
    width: 100%;
  }

  /* ── Slide 1: Intro ── */
  .pod-label {
    display: inline-block;
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--gold-primary);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.45rem 1.2rem;
    background: linear-gradient(
      135deg,
      rgba(201, 169, 97, 0.12),
      rgba(201, 169, 97, 0.05)
    );
    border: 1px solid rgba(201, 169, 97, 0.2);
    border-radius: 30px;
    margin-bottom: 1.5rem;
  }

  .pod-title {
    font-family: var(--font-heading);
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    font-weight: 300;
    line-height: 1.1;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
  }

  .pod-amp {
    background: linear-gradient(
      135deg,
      var(--gold-primary),
      var(--gold-secondary)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-style: italic;
  }

  .pod-line {
    width: 80px;
    height: 1px;
    background: linear-gradient(
      90deg,
      var(--gold-primary),
      var(--gold-secondary),
      transparent
    );
    margin-bottom: 1.5rem;
    transform-origin: left;
  }

  .pod-subtitle {
    font-size: clamp(0.95rem, 1.8vw, 1.15rem);
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 480px;
  }

  /* ── Glass Card ── */
  .pod-card--glass {
    padding: 2rem;
    border-radius: var(--radius-xl);
    background: linear-gradient(
      145deg,
      rgba(18, 18, 26, 0.7),
      rgba(25, 25, 35, 0.5)
    );
    border: 1px solid rgba(201, 169, 97, 0.12);
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
    box-shadow:
      0 0 0 1px rgba(201, 169, 97, 0.06),
      0 20px 60px rgba(0, 0, 0, 0.4);
  }

  .pod-card-header {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(201, 169, 97, 0.1);
  }

  .pod-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 14px;
    flex-shrink: 0;
  }

  .pod-icon svg {
    width: 28px;
    height: 28px;
    color: white;
  }

  .pod-icon--spotify {
    background: linear-gradient(135deg, #1db954 0%, #1ed760 100%);
    box-shadow: 0 8px 24px rgba(29, 185, 84, 0.3);
  }

  .pod-icon--youtube {
    background: linear-gradient(135deg, #ff0000 0%, #cc0000 100%);
    box-shadow: 0 8px 24px rgba(255, 0, 0, 0.3);
  }

  .pod-card-title {
    font-family: var(--font-heading);
    font-size: clamp(1.3rem, 2.5vw, 1.6rem);
    font-weight: 500;
    color: var(--text-primary);
    margin: 0 0 0.3rem;
  }

  .pod-card-platform {
    font-size: 0.75rem;
    color: var(--gold-primary);
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 600;
    margin: 0;
  }

  .pod-embed {
    position: relative;
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 1.2rem;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5);
  }

  .pod-embed iframe {
    display: block;
    width: 100%;
    border: none;
  }

  .pod-embed--spotify {
    border: 1px solid rgba(29, 185, 84, 0.2);
  }

  .pod-embed--youtube {
    border: 1px solid rgba(255, 0, 0, 0.2);
  }

  .pod-card-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Scroll Hint ── */
  .pod-scroll-hint {
    position: absolute;
    bottom: calc(var(--nav-height) + 1.5rem);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    z-index: 5;
  }

  .pod-scroll-track {
    width: 120px;
    height: 2px;
    background: rgba(201, 169, 97, 0.15);
    border-radius: 2px;
    overflow: hidden;
  }

  .pod-scroll-progress {
    height: 100%;
    width: 100%;
    background: linear-gradient(
      90deg,
      var(--gold-primary),
      var(--gold-secondary)
    );
    border-radius: 2px;
    transform-origin: left;
    transform: scaleX(0.33);
  }

  .pod-scroll-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-muted);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .pod-card--glass {
      padding: 1.5rem;
    }

    .pod-embed iframe {
      height: 260px;
    }

    .pod-card-desc {
      -webkit-line-clamp: 2;
    }
  }
</style>
