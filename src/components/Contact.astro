---

---

<section id='contact' class='contact-section'>
  <div class='container'>
    <div class='contact-wrapper'>
      <div class='contact-info'>
        <span class='section-subtitle'>Contacto</span>
        <h2 class='contact-title'>
          Inicia tu <span class='text-gold'>viaje</span>
        </h2>
        <p class='contact-desc'>
          Si estás interesado en conferencias, talleres o consultas, no dudes en
          ponerte en contacto.
        </p>

        <div class='contact-details'>
          <div class='detail-item'>
            <span class='label'>Email</span>
            <a href='mailto:info@draruiz.com' class='link-hover'
              >info@draruiz.com</a
            >
          </div>
          <div class='detail-item'>
            <span class='label'>Ubicación</span>
            <span>Tampa, Florida & Online</span>
          </div>
          <div class='detail-item'>
            <span class='label'>Redes Sociales</span>
            <div class='social-links'>
              <a href='#' target='_blank' class='link-hover'>Instagram</a>
              <a href='#' target='_blank' class='link-hover'>LinkedIn</a>
              <a href='#' target='_blank' class='link-hover'>YouTube</a>
            </div>
          </div>
        </div>
      </div>

      <div class='contact-form-wrapper'>
        <form class='contact-form'>
          <div class='form-group'>
            <input
              type='text'
              id='name'
              name='name'
              placeholder='Nombre'
              required
            />
            <label for='name'>Nombre</label>
          </div>
          <div class='form-group'>
            <input
              type='email'
              id='email'
              name='email'
              placeholder='Email'
              required
            />
            <label for='email'>Email</label>
          </div>
          <div class='form-group'>
            <textarea
              id='message'
              name='message'
              rows='4'
              placeholder='Mensaje'
              required></textarea>
            <label for='message'>Mensaje</label>
          </div>
          <button type='submit' class='btn btn-primary'>Enviar Mensaje</button>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    padding: var(--spacing-xl) 0;
    background: radial-gradient(
      ellipse at bottom,
      var(--bg-primary) 0%,
      var(--bg-secondary) 100%
    );
    position: relative;
    overflow: hidden;
  }

  .contact-section::before {
    content: "";
    position: absolute;
    bottom: -10%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(
      circle,
      rgba(201, 169, 97, 0.1) 0%,
      transparent 70%
    );
    filter: blur(100px);
    pointer-events: none;
  }

  .contact-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-lg);
    align-items: start;
  }

  .section-subtitle {
    display: inline-block;
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--gold-primary);
    margin-bottom: 1.5rem;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.5rem 1.5rem;
    background: linear-gradient(
      135deg,
      rgba(201, 169, 97, 0.1),
      rgba(201, 169, 97, 0.05)
    );
    border: 1px solid rgba(201, 169, 97, 0.2);
    border-radius: 30px;
  }

  .contact-title {
    color: var(--text-primary);
    margin-bottom: 2rem;
  }

  .text-gold {
    background: linear-gradient(135deg, var(--gold-primary), var(--gold-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-style: italic;
  }

  .contact-desc {
    font-size: 1.15rem;
    color: var(--text-secondary);
    margin-bottom: 3rem;
    line-height: 1.8;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .detail-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--gold-primary);
    font-weight: 600;
  }

  .detail-item span:not(.label),
  .detail-item a {
    color: var(--text-secondary);
    font-size: 1.1rem;
  }

  .link-hover {
    transition: all 0.3s ease;
    position: relative;
  }

  .link-hover::after {
    content: "";
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--gold-primary);
    transition: width 0.3s ease;
  }

  .link-hover:hover {
    color: var(--gold-primary);
  }

  .link-hover:hover::after {
    width: 100%;
  }

  .social-links {
    display: flex;
    gap: 2rem;
  }

  .contact-form-wrapper {
    padding: 3rem;
    border-radius: var(--radius-xl);
    background: linear-gradient(145deg, var(--bg-card) 0%, var(--bg-elevated) 100%);
    border: 1px solid rgba(201, 169, 97, 0.15);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 
      0 0 0 1px rgba(201, 169, 97, 0.1),
      0 20px 40px rgba(0, 0, 0, 0.5);
  }

  .form-group {
    margin-bottom: 2rem;
    position: relative;
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 1rem 1.5rem;
    background: rgba(10, 10, 15, 0.5);
    border: 1px solid rgba(201, 169, 97, 0.2);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 1rem;
    transition: all 0.3s ease;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--gold-primary);
    background: rgba(10, 10, 15, 0.8);
    box-shadow: 0 0 0 3px rgba(201, 169, 97, 0.1);
  }

  .form-group label {
    position: absolute;
    top: -10px;
    left: 15px;
    background: var(--bg-elevated);
    padding: 0 0.5rem;
    font-size: 0.75rem;
    color: var(--gold-primary);
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  @media (max-width: 900px) {
    .contact-wrapper {
      grid-template-columns: 1fr;
      gap: 4rem;
    }

    .contact-form-wrapper {
      padding: 2rem;
    }
  }
</style>

