---

<section id='contact' class='contact-section' aria-labelledby='contact-heading'>
  <div class='container'>
    <div class='contact-wrapper'>
      <div class='contact-info'>
        <span class='section-subtitle'>Contacto</span>
        <h2 id='contact-heading' class='contact-title'>
          Inicia tu <span class='text-gold'>viaje</span>
        </h2>
        <p class='contact-desc'>
          Si estás interesado en conferencias, talleres o consultas, no dudes en
          ponerte en contacto.
        </p>

        <div class='contact-details'>
          <div class='detail-item'>
            <span class='label'>Email</span>
            <a href='mailto:info@draalejandraruiz.com' class='link-hover'
              >info@draalejandraruiz.com</a
            >
          </div>
          <div class='detail-item'>
            <span class='label'>Ubicación</span>
            <span>Tampa, Florida & Online</span>
          </div>
          <div class='detail-item'>
            <span class='label'>Redes Sociales</span>
            <div class='social-links'>
              <a
                href='https://www.instagram.com/dramariaalejandraruiz/'
                target='_blank'
                rel='noopener noreferrer'
                class='link-hover'>Instagram</a
              >
              <a
                href='https://www.linkedin.com/in/drmarialejandraruiz'
                target='_blank'
                rel='noopener noreferrer'
                class='link-hover'>LinkedIn</a
              >
              <a
                href='https://www.youtube.com/@Pensandoenvozaltadraruiz/videos'
                target='_blank'
                rel='noopener noreferrer'
                class='link-hover'>YouTube</a
              >
            </div>
          </div>
        </div>
      </div>

      <div class='contact-form-wrapper'>
        <div class='contact-actions'>
          <p class='actions-desc'>Escríbenos directamente:</p>
          <a
            href='mailto:info@draalejandraruiz.com'
            class='btn btn-email'
            aria-label='Enviar email a info@draalejandraruiz.com'
          >
            <svg
              class='btn-icon'
              xmlns='http://www.w3.org/2000/svg'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='2'
              stroke-linecap='round'
              stroke-linejoin='round'
              ><rect width='20' height='16' x='2' y='4' rx='2'></rect><path
                d='m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7'></path></svg
            >
            Enviar Email
          </a>
          <a
            href='https://wa.me/18135686424?text=Hola%20Dra.%20Ruiz%2C%20me%20gustaría%20ponerme%20en%20contacto%20con%20usted.'
            target='_blank'
            rel='noopener noreferrer'
            class='btn btn-whatsapp'
            aria-label='Contactar por WhatsApp'
          >
            <svg
              class='btn-icon'
              xmlns='http://www.w3.org/2000/svg'
              viewBox='0 0 24 24'
              fill='currentColor'
              ><path
                d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z'
              ></path></svg
            >
            Hablar por WhatsApp
          </a>
        </div>
      </div>
    </div>

    <footer class='contact-footer'>
      <p class='footer-copyright'>
        &copy; {new Date().getFullYear()} Dra. Maria Alejandra Ruiz. Todos los derechos
        reservados.
      </p>
    </footer>
  </div>
</section>

<script>
  import { gsap } from "gsap";

  let hasAnimated = false;

  const animateContact = () => {
    if (hasAnimated) return;
    hasAnimated = true;

    const mm = gsap.matchMedia();

    mm.add("(prefers-reduced-motion: no-preference)", () => {
      const tl = gsap.timeline({
        defaults: { ease: "power3.out", duration: 0.8 },
      });

      tl.fromTo(
        ".contact-info",
        { autoAlpha: 0, x: -30 },
        { autoAlpha: 1, x: 0 },
      )
        .fromTo(
          ".contact-form-wrapper",
          { autoAlpha: 0, x: 30 },
          { autoAlpha: 1, x: 0 },
          "-=0.5",
        )
        .fromTo(
          ".contact-footer",
          { autoAlpha: 0, y: 20 },
          { autoAlpha: 1, y: 0, duration: 0.6 },
          "-=0.3",
        );
    });

    mm.add("(prefers-reduced-motion: reduce)", () => {
      gsap.set(".contact-info, .contact-form-wrapper, .contact-footer", {
        autoAlpha: 1,
        x: 0,
        y: 0,
      });
    });
  };

  document.addEventListener("sectionEnter", ((e: CustomEvent) => {
    if (e.detail.section === "contact") animateContact();
  }) as EventListener);
</script>

<style>
  .contact-section {
    padding: 4rem 0 calc(var(--nav-height) + 2rem);
    background: radial-gradient(
      ellipse at bottom,
      var(--bg-primary) 0%,
      var(--bg-secondary) 100%
    );
    position: relative;
    overflow: hidden;
  }

  .contact-section::before {
    content: "";
    position: absolute;
    bottom: -10%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(
      circle,
      rgba(201, 169, 97, 0.1) 0%,
      transparent 70%
    );
    filter: blur(100px);
    pointer-events: none;
  }

  .contact-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-lg);
    align-items: start;
  }

  .section-subtitle {
    display: inline-block;
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--gold-primary);
    margin-bottom: 1.5rem;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.5rem 1.5rem;
    background: linear-gradient(
      135deg,
      rgba(201, 169, 97, 0.1),
      rgba(201, 169, 97, 0.05)
    );
    border: 1px solid rgba(201, 169, 97, 0.2);
    border-radius: 30px;
  }

  .contact-title {
    color: var(--text-primary);
    margin-bottom: 2rem;
  }

  .text-gold {
    background: linear-gradient(
      135deg,
      var(--gold-primary),
      var(--gold-secondary)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-style: italic;
  }

  .contact-desc {
    font-size: 1.15rem;
    color: var(--text-secondary);
    margin-bottom: 3rem;
    line-height: 1.8;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .detail-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--gold-primary);
    font-weight: 600;
  }

  .detail-item span:not(.label),
  .detail-item a {
    color: var(--text-secondary);
    font-size: 1.1rem;
  }

  .link-hover {
    transition: all 0.3s ease;
    position: relative;
  }

  .link-hover::after {
    content: "";
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--gold-primary);
    transition: width 0.3s ease;
  }

  .link-hover:hover {
    color: var(--gold-primary);
  }

  .link-hover:hover::after {
    width: 100%;
  }

  .social-links {
    display: flex;
    gap: 2rem;
  }

  .contact-form-wrapper {
    padding: 3rem;
    border-radius: var(--radius-xl);
    background: linear-gradient(
      145deg,
      var(--bg-card) 0%,
      var(--bg-elevated) 100%
    );
    border: 1px solid rgba(201, 169, 97, 0.15);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow:
      0 0 0 1px rgba(201, 169, 97, 0.1),
      0 20px 40px rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .contact-actions {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    width: 100%;
  }

  .actions-desc {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
    text-align: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1.15rem 2rem;
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
    border: none;
    width: 100%;
  }

  .btn-icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .btn-email {
    background: linear-gradient(
      135deg,
      rgba(201, 169, 97, 0.15),
      rgba(201, 169, 97, 0.05)
    );
    border: 1px solid rgba(201, 169, 97, 0.3);
    color: var(--gold-primary);
  }

  .btn-email:hover {
    background: linear-gradient(
      135deg,
      rgba(201, 169, 97, 0.25),
      rgba(201, 169, 97, 0.1)
    );
    border-color: rgba(201, 169, 97, 0.5);
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(201, 169, 97, 0.15);
  }

  .btn-whatsapp {
    background: linear-gradient(135deg, #25d366, #128c7e);
    color: #fff;
    border: 1px solid transparent;
  }

  .btn-whatsapp:hover {
    background: linear-gradient(135deg, #2be774, #159e8d);
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(37, 211, 102, 0.25);
  }

  .btn:focus-visible {
    outline: 2px solid var(--gold-primary);
    outline-offset: 3px;
  }

  @media (max-width: 900px) {
    .contact-wrapper {
      grid-template-columns: 1fr;
      gap: 4rem;
    }

    .contact-form-wrapper {
      padding: 2rem;
    }
  }

  .contact-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(201, 169, 97, 0.1);
    text-align: center;
  }

  .footer-copyright {
    font-size: 0.8rem;
    color: var(--text-muted);
    letter-spacing: 1px;
  }
</style>
