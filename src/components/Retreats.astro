---

<section class='retreats-section' aria-labelledby='retreats-heading'>
  <!-- Video Background -->
  <div class='retreats-video-bg' aria-hidden='true'>
    <video
      autoplay
      muted
      loop
      playsinline
      preload='metadata'
      class='retreats-video'
    >
      <source
        src='https://videos.pexels.com/video-files/3571264/3571264-uhd_2560_1440_30fps.mp4'
        type='video/mp4'
      />
    </video>
    <div class='retreats-video-overlay'></div>
  </div>

  <!-- Horizontal scroll wrapper -->
  <div class='retreats-viewport' tabindex='0'>
    <div class='retreats-track'>
      <!-- Slide 1: Intro -->
      <div class='retreats-slide retreats-slide--intro'>
        <div class='rslide-content'>
          <span class='retreats-label'>Bienestar Integral</span>
          <h2 id='retreats-heading' class='retreats-title'>
            Retiros <span class='retreats-amp'>&</span>
            <br />Terapéuticos
          </h2>
          <div class='retreats-line' aria-hidden='true'></div>
          <p class='retreats-subtitle'>
            Espacios de sanación y reconexión interior en entornos naturales
            diseñados para tu transformación
          </p>
        </div>
      </div>

      <!-- Slide 2: Descripción del retiro -->
      <div class='retreats-slide retreats-slide--about'>
        <div class='rslide-content'>
          <div class='retreat-card retreat-card--glass'>
            <span class='retreat-icon'>
              <svg
                width='32'
                height='32'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='1.5'
                ><path
                  d='M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5'
                ></path></svg
              >
            </span>
            <h3 class='retreat-title'>La Experiencia</h3>
            <p class='retreat-desc'>
              Retiros inmersivos de 3 a 5 días que integran psicología clínica,
              mindfulness, yoga y conexión con la naturaleza para promover la
              sanación profunda y el autoconocimiento.
            </p>
            <ul class='retreat-features'>
              <li>Terapia grupal guiada</li>
              <li>Sesiones de yoga y meditación</li>
              <li>Técnicas de respiración consciente</li>
              <li>Caminatas terapéuticas</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Slide 3: Beneficios -->
      <div class='retreats-slide retreats-slide--benefits'>
        <div class='rslide-content'>
          <div class='retreat-card retreat-card--glass'>
            <span class='retreat-icon'>
              <svg
                width='32'
                height='32'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='1.5'
                ><path
                  d='M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z'
                ></path></svg
              >
            </span>
            <h3 class='retreat-title'>Beneficios</h3>
            <p class='retreat-desc'>
              Cada retiro está diseñado con un enfoque clínico respaldado por
              evidencia para generar un impacto duradero en tu bienestar mental
              y emocional.
            </p>
            <ul class='retreat-features'>
              <li>Reducción de estrés y ansiedad</li>
              <li>Claridad mental y emocional</li>
              <li>Herramientas de autocuidado</li>
              <li>Comunidad de apoyo</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Slide 4: CTA -->
      <div class='retreats-slide retreats-slide--cta'>
        <div class='rslide-content'>
          <h3 class='rcta-heading'>
            Reserva tu lugar <br />en el próximo retiro
          </h3>
          <p class='rcta-text'>
            Los cupos son limitados para garantizar una experiencia íntima y
            personalizada. Escríbenos para conocer las próximas fechas.
          </p>
          <a
            href='https://wa.me/18135686424?text=Hola%20Dra.%20Ruiz%2C%20me%20interesa%20información%20sobre%20los%20retiros%20terapéuticos.'
            target='_blank'
            rel='noopener noreferrer'
            class='rcta-whatsapp'
          >
            <svg
              width='22'
              height='22'
              viewBox='0 0 24 24'
              fill='currentColor'
              aria-hidden='true'
            >
              <path
                d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z'
              ></path>
            </svg>
            <span>Reservar mi lugar</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Horizontal scroll indicator -->
    <div class='retreats-scroll-hint' aria-hidden='true'>
      <div class='rscroll-track'>
        <div class='rscroll-progress'></div>
      </div>
      <span class='rscroll-label'>Desliza para explorar</span>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { Observer } from "gsap/Observer";

  gsap.registerPlugin(Observer);

  let hasAnimated = false;
  let observer: ReturnType<typeof Observer.create> | null = null;

  const animateRetreats = () => {
    if (hasAnimated) return;
    hasAnimated = true;

    const track = document.querySelector(".retreats-track") as HTMLElement;
    const slides = gsap.utils.toArray<HTMLElement>(".retreats-slide");
    const progress = document.querySelector(".rscroll-progress") as HTMLElement;
    const viewport = document.querySelector(
      ".retreats-viewport",
    ) as HTMLElement;

    if (!track || slides.length === 0 || !viewport) return;

    let currentSlide = 0;
    let isSliding = false;
    const totalSlides = slides.length;

    const mm = gsap.matchMedia();

    mm.add("(prefers-reduced-motion: no-preference)", () => {
      // Entrance animation
      const entranceTl = gsap.timeline({
        defaults: { ease: "power3.out" },
      });

      entranceTl
        .fromTo(
          ".retreats-label",
          { autoAlpha: 0, y: 20 },
          { autoAlpha: 1, y: 0, duration: 0.8 },
        )
        .fromTo(
          ".retreats-title",
          { autoAlpha: 0, y: 40 },
          { autoAlpha: 1, y: 0, duration: 1 },
          0.15,
        )
        .fromTo(
          ".retreats-line",
          { scaleX: 0 },
          { scaleX: 1, duration: 0.8, ease: "power3.inOut" },
          0.3,
        )
        .fromTo(
          ".retreats-subtitle",
          { autoAlpha: 0, y: 20 },
          { autoAlpha: 1, y: 0, duration: 0.8 },
          0.5,
        )
        .fromTo(
          ".retreats-scroll-hint",
          { autoAlpha: 0, y: 10 },
          { autoAlpha: 1, y: 0, duration: 0.6 },
          0.7,
        );

      // Slide navigation
      const goToSlide = (index: number) => {
        if (isSliding || index === currentSlide) return;
        if (index < 0 || index >= totalSlides) return;
        isSliding = true;

        const direction = index > currentSlide ? 1 : -1;

        gsap.to(track, {
          xPercent: -index * 100,
          duration: 0.8,
          ease: "power3.inOut",
          onComplete: () => {
            currentSlide = index;
            isSliding = false;
          },
        });

        gsap.to(progress, {
          scaleX: (index + 1) / totalSlides,
          duration: 0.8,
          ease: "power3.inOut",
        });

        const targetSlide = slides[index];
        const content = targetSlide.querySelector(".rslide-content");
        if (content) {
          gsap.fromTo(
            content,
            { autoAlpha: 0.5, x: direction * 60 },
            {
              autoAlpha: 1,
              x: 0,
              duration: 0.7,
              ease: "power3.out",
              delay: 0.15,
            },
          );
        }
      };

      gsap.set(progress, {
        scaleX: 1 / totalSlides,
        transformOrigin: "left",
      });

      observer = Observer.create({
        target: viewport,
        type: "wheel,touch,pointer",
        wheelSpeed: -1,
        onUp: () => goToSlide(currentSlide + 1),
        onDown: () => goToSlide(currentSlide - 1),
        onLeft: () => goToSlide(currentSlide + 1),
        onRight: () => goToSlide(currentSlide - 1),
        tolerance: 50,
        preventDefault: true,
      });

      viewport.addEventListener("keydown", (e: KeyboardEvent) => {
        if (e.key === "ArrowRight" || e.key === "ArrowDown") {
          e.preventDefault();
          e.stopPropagation();
          goToSlide(currentSlide + 1);
        } else if (e.key === "ArrowLeft" || e.key === "ArrowUp") {
          e.preventDefault();
          e.stopPropagation();
          goToSlide(currentSlide - 1);
        }
      });
    });

    mm.add("(prefers-reduced-motion: reduce)", () => {
      gsap.set(
        ".retreats-label, .retreats-title, .retreats-line, .retreats-subtitle, .retreats-scroll-hint",
        { autoAlpha: 1, y: 0, scaleX: 1 },
      );
      gsap.set(progress, {
        scaleX: 1 / totalSlides,
        transformOrigin: "left",
      });
    });
  };

  document.addEventListener("sectionChanged", ((e: CustomEvent) => {
    if (e.detail.section !== "retreats" && observer) {
      observer.disable();
    } else if (e.detail.section === "retreats" && observer) {
      observer.enable();
    }
  }) as EventListener);

  document.addEventListener("sectionEnter", ((e: CustomEvent) => {
    if (e.detail.section === "retreats") animateRetreats();
  }) as EventListener);
</script>

<style>
  .retreats-section {
    position: relative;
    height: 100%;
    overflow: hidden;
  }

  /* ── Video Background ── */
  .retreats-video-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .retreats-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .retreats-video-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      160deg,
      rgba(10, 10, 15, 0.9) 0%,
      rgba(12, 18, 14, 0.8) 50%,
      rgba(10, 10, 15, 0.92) 100%
    );
    z-index: 1;
  }

  /* ── Viewport ── */
  .retreats-viewport {
    position: relative;
    z-index: 2;
    height: 100%;
    overflow: hidden;
    outline: none;
  }

  /* ── Horizontal Track ── */
  .retreats-track {
    display: flex;
    height: 100%;
    will-change: transform;
  }

  .retreats-slide {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem clamp(1.5rem, 5vw, 6rem) calc(var(--nav-height) + 2rem);
  }

  .rslide-content {
    max-width: 600px;
    width: 100%;
  }

  /* ── Slide 1: Intro ── */
  .retreats-label {
    display: inline-block;
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--gold-primary);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.45rem 1.2rem;
    background: linear-gradient(
      135deg,
      rgba(201, 169, 97, 0.12),
      rgba(201, 169, 97, 0.05)
    );
    border: 1px solid rgba(201, 169, 97, 0.2);
    border-radius: 30px;
    margin-bottom: 1.5rem;
  }

  .retreats-title {
    font-family: var(--font-heading);
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    font-weight: 300;
    line-height: 1.1;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
  }

  .retreats-amp {
    background: linear-gradient(
      135deg,
      var(--gold-primary),
      var(--gold-secondary)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-style: italic;
  }

  .retreats-line {
    width: 80px;
    height: 1px;
    background: linear-gradient(
      90deg,
      var(--gold-primary),
      var(--gold-secondary),
      transparent
    );
    margin-bottom: 1.5rem;
    transform-origin: left;
  }

  .retreats-subtitle {
    font-size: clamp(0.95rem, 1.8vw, 1.15rem);
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 480px;
  }

  /* ── Retreat Cards ── */
  .retreat-card--glass {
    padding: 2.5rem;
    border-radius: var(--radius-xl);
    background: linear-gradient(
      145deg,
      rgba(18, 18, 26, 0.7),
      rgba(25, 25, 35, 0.5)
    );
    border: 1px solid rgba(201, 169, 97, 0.12);
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
    box-shadow:
      0 0 0 1px rgba(201, 169, 97, 0.06),
      0 20px 60px rgba(0, 0, 0, 0.4);
  }

  .retreat-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background: linear-gradient(
      135deg,
      rgba(201, 169, 97, 0.15),
      rgba(201, 169, 97, 0.05)
    );
    border: 1px solid rgba(201, 169, 97, 0.2);
    color: var(--gold-primary);
    margin-bottom: 1.5rem;
  }

  .retreat-title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 400;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .retreat-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .retreat-features {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.7rem;
  }

  .retreat-features li {
    font-size: 0.82rem;
    color: var(--text-secondary);
    padding-left: 1.2rem;
    position: relative;
  }

  .retreat-features li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--gold-primary);
    box-shadow: 0 0 8px rgba(201, 169, 97, 0.4);
  }

  /* ── CTA Slide ── */
  .retreats-slide--cta .rslide-content {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .rcta-heading {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 300;
    color: var(--text-primary);
    line-height: 1.2;
    margin-bottom: 1.2rem;
  }

  .rcta-text {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 420px;
    margin-bottom: 2.5rem;
  }

  .rcta-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1rem 2.5rem;
    border-radius: 50px;
    background: linear-gradient(135deg, #25d366, #128c7e);
    color: #fff;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow:
      0 4px 20px rgba(37, 211, 102, 0.3),
      0 0 0 1px rgba(37, 211, 102, 0.15);
    position: relative;
    overflow: hidden;
  }

  .rcta-whatsapp::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.15), transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
    border-radius: 50px;
  }

  .rcta-whatsapp:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow:
      0 8px 30px rgba(37, 211, 102, 0.4),
      0 0 0 1px rgba(37, 211, 102, 0.3);
  }

  .rcta-whatsapp:hover::before {
    opacity: 1;
  }

  .rcta-whatsapp:focus-visible {
    outline: 2px solid #25d366;
    outline-offset: 3px;
  }

  /* ── Scroll Hint ── */
  .retreats-scroll-hint {
    position: absolute;
    bottom: calc(var(--nav-height) + 1.5rem);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    z-index: 5;
  }

  .rscroll-track {
    width: 120px;
    height: 2px;
    background: rgba(201, 169, 97, 0.15);
    border-radius: 2px;
    overflow: hidden;
  }

  .rscroll-progress {
    height: 100%;
    width: 100%;
    background: linear-gradient(
      90deg,
      var(--gold-primary),
      var(--gold-secondary)
    );
    border-radius: 2px;
    transform-origin: left;
    transform: scaleX(0.25);
  }

  .rscroll-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-muted);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .retreat-card--glass {
      padding: 1.8rem;
    }

    .retreat-features {
      grid-template-columns: 1fr;
    }

    .rcta-whatsapp {
      padding: 0.9rem 2rem;
      font-size: 0.78rem;
    }
  }
</style>
