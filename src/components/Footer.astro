---
const currentYear = new Date().getFullYear();
---

<footer class='footer'>
  <div class='container'>
    <div class='footer-content'>
      <div class='footer-logo'>
        <span>Dra. Ruiz</span>
      </div>

      <div class='footer-links'>
        <a href='#bio'>Bio</a>
        <a href='#books'>Libros</a>
        <a href='#podcasts'>Podcast</a>
        <a href='#ceo'>CEO</a>
        <a href='#contact'>Contacto</a>
      </div>

      <div class='copyright'>
        <p>
          &copy; {currentYear} Dra. Maria Alejandra Ruiz. Todos los derechos reservados.
        </p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: linear-gradient(
      to bottom,
      var(--bg-secondary) 0%,
      #000000 100%
    );
    color: var(--text-primary);
    padding: 4rem 0 2rem;
    text-align: center;
    border-top: 1px solid rgba(201, 169, 97, 0.1);
    position: relative;
  }

  .footer::before {
    content: "";
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 300px;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(201, 169, 97, 0.5),
      transparent
    );
  }

  .footer-logo {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    margin-bottom: 3rem;
    background: linear-gradient(
      135deg,
      var(--text-primary),
      var(--gold-primary)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 400;
    letter-spacing: 2px;
  }

  .footer-links {
    display: flex;
    justify-content: center;
    gap: 3.5rem;
    margin-bottom: 4rem;
    flex-wrap: wrap;
  }

  .footer-links a {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--text-secondary);
    font-weight: 500;
    position: relative;
    transition: all 0.4s ease;
  }

  .footer-links a::after {
    content: "";
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--gold-primary);
    transition: width 0.4s ease;
  }

  .footer-links a:hover {
    color: var(--gold-primary);
  }

  .footer-links a:hover::after {
    width: 100%;
  }

  .copyright {
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 1px;
    padding-top: 2rem;
    border-top: 1px solid rgba(201, 169, 97, 0.05);
    margin: 0 auto;
    max-width: 600px;
  }

  .copyright p {
    margin: 0;
  }

  @media (max-width: 768px) {
    .footer-links {
      gap: 2rem;
    }

    .footer-logo {
      font-size: 2rem;
    }
  }
</style>
