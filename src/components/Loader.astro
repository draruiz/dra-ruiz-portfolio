---
import mainLogo from "../assets/main_logo_brain.png";
---

<div id='luxury-loader' class='loader' role='dialog' aria-label='Bienvenida'>
  <div class='loader-bg'></div>
  <div class='loader-grain' aria-hidden='true'></div>

  <!-- Partículas decorativas -->
  <div class='loader-particles' aria-hidden='true'>
    <span class='lp'></span><span class='lp'></span><span class='lp'></span>
    <span class='lp'></span><span class='lp'></span><span class='lp'></span>
    <span class='lp'></span><span class='lp'></span>
  </div>

  <div class='loader-content'>
    <!-- Logo -->
    <div class='loader-logo'>
      <div class='logo-ring' aria-hidden='true'></div>
      <img
        src={mainLogo.src}
        alt='Logo Dra. Maria Alejandra Ruiz'
        class='loader-logo-img'
        width='160'
        height='160'
      />
    </div>

    <!-- Línea dorada -->
    <div class='loader-line' aria-hidden='true'></div>

    <!-- Texto -->
    <div class='loader-text'>
      <span class='loader-name'>Dra. Maria Alejandra Ruiz</span>
      <span class='loader-title'
        >Psicóloga Clínica · Autora · Conferencista</span
      >
    </div>

    <!-- Botón de entrada -->
    <button
      class='loader-enter-btn'
      id='loader-enter'
      type='button'
      aria-label='Entrar al sitio'
    >
      <span class='enter-text'>Explorar</span>
      <span class='enter-icon' aria-hidden='true'>
        <svg
          width='18'
          height='18'
          viewBox='0 0 24 24'
          fill='none'
          stroke='currentColor'
          stroke-width='2'
          stroke-linecap='round'
          stroke-linejoin='round'
        >
          <line x1='5' y1='12' x2='19' y2='12'></line>
          <polyline points='12 5 19 12 12 19'></polyline>
        </svg>
      </span>
    </button>

    <span class='loader-hint'>Haz click para comenzar la experiencia</span>
  </div>
</div>

<script>
  import { gsap } from "gsap";

  const loader = document.getElementById("luxury-loader") as HTMLElement;
  const enterBtn = document.getElementById("loader-enter") as HTMLButtonElement;

  if (loader && enterBtn) {
    // Entrance animation timeline
    const entranceTl = gsap.timeline({ defaults: { ease: "power3.out" } });

    entranceTl
      .fromTo(
        ".loader-logo-img",
        { autoAlpha: 0, scale: 0.7, rotation: -10 },
        {
          autoAlpha: 1,
          scale: 1,
          rotation: 0,
          duration: 1.2,
          ease: "back.out(1.4)",
        },
        0.3,
      )
      .fromTo(
        ".logo-ring",
        { autoAlpha: 0, scale: 0.5, rotation: -180 },
        {
          autoAlpha: 1,
          scale: 1,
          rotation: 0,
          duration: 1.5,
          ease: "power3.out",
        },
        0.2,
      )
      .fromTo(
        ".loader-line",
        { scaleX: 0 },
        { scaleX: 1, duration: 0.8, ease: "power3.inOut" },
        0.8,
      )
      .fromTo(
        ".loader-name",
        { autoAlpha: 0, y: 30, clipPath: "inset(0 100% 0 0)" },
        { autoAlpha: 1, y: 0, clipPath: "inset(0 0% 0 0)", duration: 0.9 },
        1.0,
      )
      .fromTo(
        ".loader-title",
        { autoAlpha: 0, y: 20 },
        { autoAlpha: 1, y: 0, duration: 0.7 },
        1.3,
      )
      .fromTo(
        ".loader-enter-btn",
        { autoAlpha: 0, y: 20, scale: 0.9 },
        { autoAlpha: 1, y: 0, scale: 1, duration: 0.8, ease: "back.out(1.7)" },
        1.6,
      )
      .fromTo(
        ".loader-hint",
        { autoAlpha: 0 },
        { autoAlpha: 0.5, duration: 0.5 },
        2.0,
      );

    // Floating particles
    gsap.utils.toArray<HTMLElement>(".lp").forEach((p, i) => {
      gsap.fromTo(
        p,
        { autoAlpha: 0, scale: 0 },
        {
          autoAlpha: gsap.utils.random(0.2, 0.6),
          scale: 1,
          duration: 1,
          delay: 0.5 + i * 0.15,
          ease: "power2.out",
        },
      );
      gsap.to(p, {
        y: gsap.utils.random(-50, 50),
        x: gsap.utils.random(-40, 40),
        duration: gsap.utils.random(3, 7),
        repeat: -1,
        yoyo: true,
        ease: "sine.inOut",
        delay: i * 0.3,
      });
    });

    // Pulsing ring
    gsap.to(".logo-ring", {
      scale: 1.08,
      autoAlpha: 0.6,
      duration: 2,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut",
      delay: 1.5,
    });

    // Enter button click handler
    enterBtn.addEventListener("click", () => {
      // Start music
      document.dispatchEvent(new CustomEvent("startMusic"));

      // Exit animation
      const exitTl = gsap.timeline({
        onComplete: () => {
          loader.classList.add("hidden");
          document.dispatchEvent(new CustomEvent("loaderComplete"));
        },
      });

      exitTl
        .to(".loader-hint", { autoAlpha: 0, duration: 0.2 })
        .to(
          ".loader-enter-btn",
          { autoAlpha: 0, y: -10, scale: 0.9, duration: 0.3 },
          0,
        )
        .to(".loader-text", { autoAlpha: 0, y: -20, duration: 0.4 }, 0.1)
        .to(".loader-line", { scaleX: 0, duration: 0.3 }, 0.15)
        .to(".loader-logo", { autoAlpha: 0, scale: 1.1, duration: 0.5 }, 0.2)
        .to(
          ".lp",
          { autoAlpha: 0, scale: 0, duration: 0.3, stagger: 0.02 },
          0.1,
        )
        .to(".loader-bg", { autoAlpha: 0, duration: 0.6 }, 0.3)
        .to(loader, { autoAlpha: 0, duration: 0.3 }, 0.6);
    });
  }
</script>

<style>
  .loader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: all;
  }

  .loader.hidden {
    display: none;
    pointer-events: none;
  }

  .loader-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #0a0a0f 0%, #12121a 50%, #0a0a0f 100%);
    z-index: 1;
  }

  .loader-bg::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 800px;
    height: 800px;
    background: radial-gradient(
      circle,
      rgba(201, 169, 97, 0.12) 0%,
      rgba(201, 169, 97, 0.04) 40%,
      transparent 70%
    );
    filter: blur(100px);
  }

  .loader-grain {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    opacity: 0.03;
    z-index: 2;
    pointer-events: none;
  }

  /* Partículas */
  .loader-particles {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
  }

  .lp {
    position: absolute;
    width: 4px;
    height: 4px;
    background: var(--gold-primary);
    border-radius: 50%;
    box-shadow: 0 0 10px var(--gold-glow);
    opacity: 0;
  }

  .lp:nth-child(1) {
    top: 15%;
    left: 10%;
    width: 3px;
    height: 3px;
  }
  .lp:nth-child(2) {
    top: 25%;
    right: 15%;
    width: 5px;
    height: 5px;
  }
  .lp:nth-child(3) {
    bottom: 30%;
    left: 20%;
  }
  .lp:nth-child(4) {
    top: 60%;
    right: 10%;
    width: 3px;
    height: 3px;
  }
  .lp:nth-child(5) {
    bottom: 15%;
    left: 40%;
    width: 6px;
    height: 6px;
  }
  .lp:nth-child(6) {
    top: 10%;
    left: 50%;
    width: 3px;
    height: 3px;
  }
  .lp:nth-child(7) {
    bottom: 25%;
    right: 25%;
    width: 4px;
    height: 4px;
  }
  .lp:nth-child(8) {
    top: 45%;
    left: 75%;
    width: 3px;
    height: 3px;
  }

  /* Content */
  .loader-content {
    position: relative;
    z-index: 4;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  /* Logo */
  .loader-logo {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-ring {
    position: absolute;
    width: 200px;
    height: 200px;
    border: 1px solid rgba(201, 169, 97, 0.2);
    border-radius: 50%;
    box-shadow:
      0 0 40px rgba(201, 169, 97, 0.08),
      inset 0 0 40px rgba(201, 169, 97, 0.05);
  }

  .loader-logo-img {
    width: clamp(100px, 20vw, 160px);
    height: auto;
    filter: drop-shadow(0 0 40px rgba(201, 169, 97, 0.5));
    position: relative;
    z-index: 1;
  }

  /* Line */
  .loader-line {
    width: 120px;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--gold-primary),
      var(--gold-secondary),
      var(--gold-primary),
      transparent
    );
    transform-origin: center;
    box-shadow: 0 0 15px rgba(201, 169, 97, 0.3);
  }

  /* Text */
  .loader-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
  }

  .loader-name {
    font-family: var(--font-heading);
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.9);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .loader-title {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold-primary);
    opacity: 0.8;
  }

  /* Enter button */
  .loader-enter-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1rem 2.8rem;
    margin-top: 1rem;
    border: 1px solid rgba(201, 169, 97, 0.3);
    border-radius: 50px;
    background: linear-gradient(
      145deg,
      rgba(25, 25, 35, 0.5),
      rgba(15, 15, 22, 0.7)
    );
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    color: var(--gold-primary);
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 3px;
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow:
      0 0 0 1px rgba(201, 169, 97, 0.1),
      0 10px 40px rgba(0, 0, 0, 0.4);
    position: relative;
    overflow: hidden;
  }

  .loader-enter-btn::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(201, 169, 97, 0.15), transparent);
    opacity: 0;
    transition: opacity 0.4s ease;
    border-radius: 50px;
  }

  .loader-enter-btn:hover::before {
    opacity: 1;
  }

  .loader-enter-btn:hover {
    border-color: rgba(201, 169, 97, 0.6);
    transform: translateY(-2px);
    box-shadow:
      0 0 0 1px rgba(201, 169, 97, 0.3),
      0 15px 50px rgba(0, 0, 0, 0.5),
      0 0 40px rgba(201, 169, 97, 0.15);
  }

  .loader-enter-btn:focus-visible {
    outline: 2px solid var(--gold-primary);
    outline-offset: 3px;
  }

  .enter-text {
    position: relative;
    z-index: 1;
  }

  .enter-icon {
    position: relative;
    z-index: 1;
    display: flex;
    transition: transform 0.3s ease;
  }

  .loader-enter-btn:hover .enter-icon {
    transform: translateX(4px);
  }

  .loader-hint {
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 1px;
    color: var(--text-muted);
    opacity: 0;
  }

  @media (max-width: 480px) {
    .loader-enter-btn {
      padding: 0.9rem 2.2rem;
      font-size: 0.72rem;
    }

    .logo-ring {
      width: 150px;
      height: 150px;
    }
  }
</style>
