---
import mainLogo from "../assets/main_logo_brain.png";
---

<div id='luxury-loader' class='loader'>
  <div class='loader-bg'></div>
  <div class='film-grain'></div>

  <div class='loader-content'>
    <div class='loader-logo'>
      <div class='logo-image-wrapper'>
        <img src={mainLogo.src} alt='Dra. Ruiz' class='logo-image' />
      </div>
      <div class='logo-line'></div>
    </div>

    <div class='loader-text'>
      <span class='loader-name'>Dra. Maria Alejandra Ruiz</span>
      <span class='loader-title'>Psicóloga Clínica</span>
    </div>

    <div class='loader-progress'>
      <div class='progress-track'>
        <div class='progress-fill'></div>
        <div class='progress-shimmer'></div>
      </div>
    </div>
  </div>
</div>

<style>
  .loader {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: all;
  }

  .loader-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #0a0a0f 0%, #12121a 50%, #0a0a0f 100%);
    z-index: 1;
  }

  .loader-bg::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 800px;
    height: 800px;
    background: radial-gradient(
      circle,
      rgba(201, 169, 97, 0.15) 0%,
      rgba(201, 169, 97, 0.05) 40%,
      transparent 70%
    );
    filter: blur(100px);
    animation: loaderPulse 3s ease-in-out infinite;
  }

  .film-grain {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    opacity: 0.03;
    z-index: 2;
    pointer-events: none;
    animation: grainShift 0.5s steps(10) infinite;
  }

  @keyframes grainShift {
    0%,
    100% {
      transform: translate(0, 0);
    }
    10% {
      transform: translate(-2%, -2%);
    }
    20% {
      transform: translate(2%, 2%);
    }
    30% {
      transform: translate(-1%, 1%);
    }
    40% {
      transform: translate(1%, -1%);
    }
    50% {
      transform: translate(-2%, 2%);
    }
    60% {
      transform: translate(2%, -2%);
    }
    70% {
      transform: translate(-1%, -1%);
    }
    80% {
      transform: translate(1%, 1%);
    }
    90% {
      transform: translate(-2%, -1%);
    }
  }

  .loader-content {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
  }

  .loader-logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .logo-image-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(30px) scale(0.9);
    animation: logoReveal 1s cubic-bezier(0.4, 0, 0.2, 1) 0.2s forwards;
  }

  .logo-image {
    width: clamp(120px, 25vw, 200px);
    height: auto;
    filter: drop-shadow(0 0 40px rgba(201, 169, 97, 0.5));
    animation: logoGlow 3s ease-in-out infinite;
  }

  @keyframes logoReveal {
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes logoGlow {
    0%,
    100% {
      filter: drop-shadow(0 0 40px rgba(201, 169, 97, 0.5));
    }
    50% {
      filter: drop-shadow(0 0 60px rgba(201, 169, 97, 0.8));
    }
  }

  .logo-line {
    width: 0;
    height: 2px;
    background: linear-gradient(
      90deg,
      transparent,
      #c9a961,
      #d4af37,
      #c9a961,
      transparent
    );
    animation: lineExpand 0.8s cubic-bezier(0.4, 0, 0.2, 1) 0.6s forwards;
    box-shadow: 0 0 20px rgba(201, 169, 97, 0.5);
  }

  @keyframes lineExpand {
    to {
      width: 120px;
    }
  }

  .loader-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    animation: fadeInUp 0.8s ease-out 0.8s forwards;
  }

  .loader-name {
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.9);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .loader-title {
    font-family: "Inter", sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #c9a961;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .loader-progress {
    width: 200px;
    opacity: 0;
    animation: fadeIn 0.5s ease-out 1.2s forwards;
  }

  .progress-track {
    width: 100%;
    height: 2px;
    background: rgba(201, 169, 97, 0.15);
    border-radius: 2px;
    overflow: hidden;
    position: relative;
  }

  .progress-fill {
    height: 100%;
    width: 0;
    background: linear-gradient(90deg, #c9a961, #d4af37);
    border-radius: 2px;
    animation: progressFill 2s cubic-bezier(0.4, 0, 0.2, 1) 1.4s forwards;
  }

  .progress-shimmer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.4),
      transparent
    );
    transform: translateX(-100%);
    animation: shimmerMove 1.5s ease-in-out 1.6s infinite;
  }

  @keyframes progressFill {
    to {
      width: 100%;
    }
  }

  @keyframes shimmerMove {
    to {
      transform: translateX(100%);
    }
  }

  @keyframes fadeIn {
    to {
      opacity: 1;
    }
  }

  @keyframes loaderPulse {
    0%,
    100% {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1);
    }
    50% {
      opacity: 0.8;
      transform: translate(-50%, -50%) scale(1.1);
    }
  }

  /* Loader exit animation */
  .loader.fade-out {
    animation: loaderFadeOut 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  .loader.fade-out .loader-content {
    animation: contentFadeUp 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  @keyframes loaderFadeOut {
    0% {
      opacity: 1;
      visibility: visible;
    }
    100% {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
    }
  }

  @keyframes contentFadeUp {
    to {
      opacity: 0;
      transform: translateY(-30px) scale(0.95);
    }
  }

  .loader.hidden {
    display: none;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const loader = document.getElementById("luxury-loader");

    // Minimum display time for the loader
    const minDisplayTime = 2800;
    const startTime = Date.now();

    const hideLoader = () => {
      const elapsedTime = Date.now() - startTime;
      const remainingTime = Math.max(0, minDisplayTime - elapsedTime);

      setTimeout(() => {
        if (loader) {
          loader.classList.add("fade-out");

          // Remove from DOM after animation
          setTimeout(() => {
            loader.classList.add("hidden");
          }, 800);
        }
      }, remainingTime);
    };

    // Hide loader when page is fully loaded
    if (document.readyState === "complete") {
      hideLoader();
    } else {
      window.addEventListener("load", hideLoader);
    }
  });
</script>
