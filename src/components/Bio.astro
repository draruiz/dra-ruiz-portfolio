---
import bioText from "../assets/bio.txt?raw";

// Split bio text into paragraphs
const paragraphs = bioText.split("\n").filter((line) => line.trim() !== "");
---

<section id='bio' class='bio-section'>
  <div class='container bio-container'>
    <div class='bio-image-wrapper'>
      <div class='bio-image'>
        <img
          src='https://imagedelivery.net/B5r6pMfQRTYBHyjgaDFr8w/db5ffc10-23fb-4d79-ba04-efe71134ca00/public'
          alt='Dra. Maria Alejandra Ruiz'
        />
        <div class='image-overlay'></div>
      </div>
      <div class='decorative-border'></div>
    </div>

    <div class='bio-content'>
      <span class='section-subtitle'>Sobre Mí</span>
      <h2 class='bio-title'>
        Una vida dedicada a la <span class='text-gold'>mente humana</span>
      </h2>

      <div class='bio-text'>
        {
          paragraphs.map((paragraph) => (
            <p class='bio-paragraph'>{paragraph}</p>
          ))
        }
      </div>

      <div class='signature'>
        <p>Maria Alejandra Ruiz</p>
      </div>
    </div>
  </div>
</section>

<style>
  .bio-section {
    padding: var(--spacing-xl) 0;
    background: linear-gradient(
      to bottom,
      var(--bg-secondary) 0%,
      var(--bg-primary) 50%,
      var(--bg-secondary) 100%
    );
    position: relative;
    overflow: hidden;
  }

  .bio-section::before {
    content: "";
    position: absolute;
    top: -10%;
    right: -5%;
    width: 600px;
    height: 600px;
    background: radial-gradient(
      circle,
      rgba(201, 169, 97, 0.08) 0%,
      transparent 70%
    );
    filter: blur(80px);
    pointer-events: none;
  }

  .bio-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-lg);
    align-items: center;
  }

  .bio-image-wrapper {
    position: relative;
    padding: 2rem;
  }

  .bio-image {
    position: relative;
    z-index: 2;
    overflow: hidden;
    border-radius: var(--radius-lg);
    box-shadow:
      0 0 0 1px rgba(201, 169, 97, 0.2),
      0 30px 60px rgba(0, 0, 0, 0.6),
      0 0 80px rgba(201, 169, 97, 0.15);
    transition: all var(--transition-premium);
    filter: grayscale(20%) contrast(110%);
  }

  .bio-image:hover {
    filter: grayscale(0%) contrast(100%);
    transform: translateY(-10px);
    box-shadow:
      0 0 0 1px rgba(201, 169, 97, 0.4),
      0 40px 80px rgba(0, 0, 0, 0.7),
      0 0 120px rgba(201, 169, 97, 0.25);
  }

  .bio-image img {
    width: 100%;
    height: auto;
    display: block;
    transform: scale(1.05);
  }

  .image-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      transparent 50%,
      rgba(10, 10, 15, 0.6) 100%
    );
    pointer-events: none;
    z-index: 1;
  }

  .decorative-border {
    position: absolute;
    bottom: -10px;
    left: -10px;
    width: calc(100% - 40px);
    height: calc(100% - 40px);
    border: 2px solid rgba(201, 169, 97, 0.2);
    border-radius: var(--radius-lg);
    z-index: 1;
    transition: all 0.5s ease;
  }

  .bio-image-wrapper:hover .decorative-border {
    border-color: rgba(201, 169, 97, 0.4);
    transform: translate(-5px, -5px);
  }

  .bio-content {
    padding-left: var(--spacing-md);
  }

  .section-subtitle {
    display: inline-block;
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--gold-primary);
    margin-bottom: 1.5rem;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.5rem 1.5rem;
    background: linear-gradient(
      135deg,
      rgba(201, 169, 97, 0.1),
      rgba(201, 169, 97, 0.05)
    );
    border: 1px solid rgba(201, 169, 97, 0.2);
    border-radius: 30px;
  }

  .bio-title {
    color: var(--text-primary);
    margin-bottom: 3rem;
    line-height: 1.2;
  }

  .text-gold {
    background: linear-gradient(
      135deg,
      var(--gold-primary),
      var(--gold-secondary)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-style: italic;
    font-weight: 600;
  }

  .bio-text {
    color: var(--text-secondary);
    font-size: 1.15rem;
    line-height: 1.9;
    font-weight: 300;
  }

  .bio-paragraph {
    margin-bottom: 2rem;
    position: relative;
    padding-left: 1.5rem;
    animation: fadeInUp 0.8s ease-out both;
  }

  .bio-paragraph:nth-child(1) {
    animation-delay: 0.2s;
  }

  .bio-paragraph:nth-child(2) {
    animation-delay: 0.3s;
  }

  .bio-paragraph:nth-child(3) {
    animation-delay: 0.4s;
  }

  .bio-paragraph:nth-child(4) {
    animation-delay: 0.5s;
  }

  .bio-paragraph::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.5rem;
    width: 3px;
    height: 0;
    background: linear-gradient(
      to bottom,
      var(--gold-primary),
      var(--gold-secondary)
    );
    border-radius: 2px;
    transition: height 0.6s ease;
  }

  .signature {
    margin-top: 4rem;
    padding: 2rem;
    border-radius: var(--radius-md);
    background: linear-gradient(
      135deg,
      rgba(201, 169, 97, 0.08),
      rgba(201, 169, 97, 0.03)
    );
    border: 1px solid rgba(201, 169, 97, 0.15);
    position: relative;
    overflow: hidden;
    animation: fadeIn 1s ease-out 0.8s both;
  }

  .signature::before {
    content: "";
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(201, 169, 97, 0.1),
      transparent
    );
    animation: slideShine 3s ease-in-out infinite;
  }

  @keyframes slideShine {
    0% {
      left: -100%;
    }
    50%,
    100% {
      left: 100%;
    }
  }

  .signature p {
    font-family: "Cormorant Garamond", serif;
    font-size: 2.8rem;
    background: linear-gradient(
      135deg,
      var(--gold-primary),
      var(--gold-secondary)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-style: italic;
    font-weight: 600;
    margin: 0;
    position: relative;
    z-index: 1;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @media (max-width: 900px) {
    .bio-container {
      grid-template-columns: 1fr;
    }

    .bio-content {
      padding-left: 0;
      margin-top: var(--spacing-md);
    }

    .bio-image-wrapper {
      padding: 1rem;
    }

    .signature p {
      font-size: 2rem;
    }
  }
</style>
