---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Portfolio de la Dra. Maria Alejandra Ruiz, Psicóloga Clínica especializada en salud mental y bienestar emocional.",
} = Astro.props;
---

<!doctype html>
<html lang='es'>
  <head>
    <meta charset='UTF-8' />
    <meta name='description' content={description} />
    <meta name='viewport' content='width=device-width' />
    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <meta name='generator' content={Astro.generator} />

    <!-- Google Fonts -->
    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
    <link
      href='https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap'
      rel='stylesheet'
    />

    <title>{title}</title>
  </head>
  <body>
    <div class='bg-orb orb-top-right'></div>
    <div class='bg-grid'></div>

    <slot />

    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);
    </script>

    <style is:global>
      .bg-orb {
        position: fixed;
        pointer-events: none;
        z-index: 0;
      }

      .orb-top-right {
        top: -15%;
        right: -5%;
        width: 700px;
        height: 700px;
        background: radial-gradient(
          circle,
          rgba(201, 169, 97, 0.15) 0%,
          rgba(201, 169, 97, 0.05) 30%,
          transparent 70%
        );
        filter: blur(100px);
        animation: pulse 8s ease-in-out infinite;
      }

      .bg-grid {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: linear-gradient(
            rgba(201, 169, 97, 0.03) 1px,
            transparent 1px
          ),
          linear-gradient(90deg, rgba(201, 169, 97, 0.03) 1px, transparent 1px);
        background-size: 50px 50px;
        opacity: 0.4;
        pointer-events: none;
        z-index: 0;
      }

      @keyframes pulse {
        0%,
        100% {
          opacity: 1;
          transform: scale(1);
        }
        50% {
          opacity: 0.8;
          transform: scale(1.1);
        }
      }
    </style>
  </body>
</html>
