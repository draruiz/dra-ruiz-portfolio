---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";

const paragraphs = [
  "Maria Alejandra se destaca como una profesional dedicada y apasionada en el fascinante mundo de la psicología, cuyo viaje ha sido tan fascinante como las mentes que ha explorado y guiado hacia la autorreflexión y el crecimiento.",
  "Maria Alejandra nació en Medellín, Colombia y comenzó su viaje académico con una determinación firme de comprender las complejidades de la mente humana. Se formó académicamente en los Estados Unidos, en donde culminó su trabajo de pregrado en psicología en la universidad estatal Rutgers University en New Jersey, Estados Unidos.",
  "Allí adquirió conocimientos teóricos y trabajó con el departamento de justicia para crear métodos en intervenciones que permitieron la conceptualización de los nexos emocionales y desarrollo de la confianza en niños que habían sufrido abandono, abuso y negligencia grave.",
  "Después de obtener su maestría y doctorado en psicología clínica en el estado de Florida, Maria Alejandra aplicó sus habilidades en entornos clínicos e investigativos, uniendo la teoría psicológica a la práctica. La experiencia que obtuvo en prisiones de máxima seguridad en los Estados Unidos le dio una comprensión profunda de cómo las personas se ven afectadas por la falta de regulación emocional, y las relaciones traumáticas.",
  "Maria Alejandra fundó Healthy Mind Specialists, la clínica de ansiedad en el estado de Tampa, Florida. Ha sido una voz activa en la divulgación y educación en salud mental más allá de la consulta privada. Ha compartido su conocimiento para empoderar a la comunidad con herramientas prácticas para el bienestar emocional a través de charlas en conferencias y participación en programas educativos.",
  "Actualmente le acompaña un grupo de terapeutas expertos de habla hispana que han tenido un gran impacto en cientos de personas en más de 20 países.",
  "Maria Alejandra está a punto de iluminar el mundo con su nuevo libro que aborda las heridas de la infancia y el apego emocional, en un fascinante cruce entre la teoría psicológica y la experiencia humana.",
  "Su obra refleja no solo un profundo conocimiento académico de las conexiones, sino también la sabiduría que ha obtenido de una carrera dedicada a comprender y alimentar las conexiones humanas.",
  "Su meta más ambiciosa consiste en establecer programas de mentorías a nivel internacional que le permita guiar y compartir sus conocimientos con aquellos terapeutas en formación en Latinoamérica. Con esto lograr que un gran número de terapeutas en diferentes países adquieran los recursos y el conocimiento necesario para ayudar a miles de personas a transitar sus problemas de vínculo afectivo y apego emocional.",
];

const milestones = [
  {
    year: "Colombia",
    text: "Nace en Medellín con la vocación de comprender la mente humana",
  },
  {
    year: "Rutgers",
    text: "Pregrado en psicología — trabajo con el departamento de justicia",
  },
  { year: "Florida", text: "Maestría y doctorado en psicología clínica" },
  {
    year: "Tampa",
    text: "Funda Healthy Mind Specialists — clínica de ansiedad",
  },
  {
    year: "Global",
    text: "Equipo de terapeutas hispanohablantes en más de 20 países",
  },
  {
    year: "Hoy",
    text: "Nuevo libro sobre heridas de infancia y apego emocional",
  },
];
---

<Layout
  title='Sobre Mí — Dra. Maria Alejandra Ruiz | Psicóloga Clínica'
  description='Conoce la historia de la Dra. Maria Alejandra Ruiz: psicóloga clínica, autora y conferencista. De Medellín a Tampa, una vida dedicada a la salud mental.'
>
  <Navigation />
  <main id='main-content'>
    <!-- Hero de la página About -->
    <section class='about-hero' aria-labelledby='about-heading'>
      <div class='container about-hero-content'>
        <span class='section-subtitle'>Mi Historia</span>
        <h1 id='about-heading' class='about-title'>
          Dra. Maria Alejandra <span class='text-gold'>Ruiz</span>
        </h1>
        <p class='about-tagline'>Psicóloga Clínica · Autora · Conferencista</p>
      </div>
    </section>

    <!-- Foto + Biografía completa -->
    <section class='about-bio' aria-labelledby='about-bio-heading'>
      <div class='container about-bio-container'>
        <div class='about-image-col'>
          <figure class='about-image-wrapper'>
            <div class='about-image-reveal'>
              <img
                src='https://imagedelivery.net/B5r6pMfQRTYBHyjgaDFr8w/419fe35b-68e5-43f1-821d-872ec5796b00/public'
                alt='Dra. Maria Alejandra Ruiz, psicóloga clínica especializada en bienestar emocional, apego y salud mental'
                width='600'
                height='750'
                loading='eager'
                decoding='async'
              />
            </div>
            <figcaption class='about-image-caption'>
              Dra. Maria Alejandra Ruiz — Tampa, Florida
            </figcaption>
          </figure>
        </div>

        <div class='about-text-col'>
          <h2 id='about-bio-heading' class='sr-only'>Biografía completa</h2>
          {
            paragraphs.map((paragraph, i) => (
              <p class='about-paragraph' data-index={i}>
                {paragraph}
              </p>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Timeline / Hitos -->
    <section class='about-timeline' aria-labelledby='timeline-heading'>
      <div class='container'>
        <h2 id='timeline-heading' class='timeline-title'>
          Un camino de <span class='text-gold'>transformación</span>
        </h2>

        <div class='timeline-track'>
          <div class='timeline-line' aria-hidden='true'>
            <div class='timeline-line-fill'></div>
          </div>
          {
            milestones.map((m, i) => (
              <div class='timeline-item' data-index={i}>
                <span class='timeline-dot' aria-hidden='true' />
                <span class='timeline-year'>{m.year}</span>
                <p class='timeline-text'>{m.text}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CTA final -->
    <section class='about-cta' aria-label='Volver al inicio'>
      <div class='container about-cta-inner'>
        <p class='about-cta-text'>¿Quieres saber más sobre mi trabajo?</p>
        <div class='about-cta-buttons'>
          <a href='/#books' class='btn'>Mis Libros</a>
          <a href='/#podcasts' class='btn'>Mis Podcasts</a>
          <a href='/#contact' class='btn btn-primary'>Contacto</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { SplitText } from "gsap/SplitText";

  gsap.registerPlugin(ScrollTrigger, SplitText);

  const mm = gsap.matchMedia();

  mm.add(
    {
      isDesktop: "(min-width: 901px)",
      isMobile: "(max-width: 900px)",
      motionOk: "(prefers-reduced-motion: no-preference)",
      motionReduce: "(prefers-reduced-motion: reduce)",
    },
    (context) => {
      const { motionReduce, isDesktop } = context.conditions as Record<
        string,
        boolean
      >;

      if (motionReduce) {
        gsap.set(
          ".about-hero-content, .about-image-wrapper, .about-paragraph, .timeline-item, .about-cta-inner, .timeline-line-fill",
          { autoAlpha: 1, y: 0, x: 0, scale: 1, clipPath: "none" },
        );
        gsap.set(".timeline-line-fill", { scaleY: 1 });
        return;
      }

      // === HERO ===
      const heroTl = gsap.timeline({ delay: 0.3 });

      SplitText.create(".about-title", {
        type: "words, chars",
        autoSplit: true,
        mask: "words",
        onSplit(self) {
          heroTl.from(self.chars, {
            y: "100%",
            opacity: 0,
            stagger: 0.02,
            duration: 0.6,
            ease: "power4.out",
          });
        },
      });

      heroTl
        .fromTo(
          ".about-hero .section-subtitle",
          { autoAlpha: 0, y: 20 },
          { autoAlpha: 1, y: 0, duration: 0.5, ease: "back.out(1.7)" },
          0,
        )
        .fromTo(
          ".about-tagline",
          { autoAlpha: 0, y: 15 },
          { autoAlpha: 1, y: 0, duration: 0.5, ease: "power2.out" },
          0.5,
        );

      // === IMAGEN: clip-path reveal ===
      gsap.fromTo(
        ".about-image-reveal",
        { clipPath: "inset(100% 0% 0% 0%)" },
        {
          clipPath: "inset(0% 0% 0% 0%)",
          duration: 1.2,
          ease: "power4.inOut",
          scrollTrigger: {
            trigger: ".about-image-wrapper",
            start: "top 75%",
          },
        },
      );

      gsap.fromTo(
        ".about-image-reveal img",
        { scale: 1.2 },
        {
          scale: 1,
          duration: 1.4,
          ease: "power3.out",
          scrollTrigger: {
            trigger: ".about-image-wrapper",
            start: "top 75%",
          },
        },
      );

      // === PÁRRAFOS con stagger individual ===
      gsap.utils.toArray<HTMLElement>(".about-paragraph").forEach((p) => {
        gsap.fromTo(
          p,
          { autoAlpha: 0, y: 25 },
          {
            autoAlpha: 1,
            y: 0,
            duration: 0.7,
            ease: "power2.out",
            scrollTrigger: {
              trigger: p,
              start: "top 85%",
            },
          },
        );
      });

      // === TIMELINE: línea que crece + items ===
      gsap.fromTo(
        ".timeline-line-fill",
        { scaleY: 0 },
        {
          scaleY: 1,
          ease: "none",
          scrollTrigger: {
            trigger: ".timeline-track",
            start: "top 70%",
            end: "bottom 40%",
            scrub: 0.8,
          },
        },
      );

      gsap.utils.toArray<HTMLElement>(".timeline-item").forEach((item, i) => {
        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: item,
            start: "top 82%",
          },
        });

        tl.fromTo(
          item.querySelector(".timeline-dot"),
          { scale: 0, autoAlpha: 0 },
          { scale: 1, autoAlpha: 1, duration: 0.4, ease: "back.out(2)" },
        )
          .fromTo(
            item.querySelector(".timeline-year"),
            { autoAlpha: 0, x: -15 },
            { autoAlpha: 1, x: 0, duration: 0.4, ease: "power2.out" },
            0.1,
          )
          .fromTo(
            item.querySelector(".timeline-text"),
            { autoAlpha: 0, y: 15 },
            { autoAlpha: 1, y: 0, duration: 0.5, ease: "power2.out" },
            0.2,
          );
      });

      // === PARALLAX imagen (desktop) ===
      if (isDesktop) {
        gsap.to(".about-image-wrapper", {
          y: -50,
          ease: "none",
          scrollTrigger: {
            trigger: ".about-bio",
            start: "top bottom",
            end: "bottom top",
            scrub: 1,
          },
        });
      }

      // === CTA final ===
      gsap.fromTo(
        ".about-cta-inner",
        { autoAlpha: 0, y: 30 },
        {
          autoAlpha: 1,
          y: 0,
          duration: 0.7,
          ease: "power2.out",
          scrollTrigger: {
            trigger: ".about-cta",
            start: "top 85%",
          },
        },
      );
    },
  );
</script>

<style>
  /* Hero */
  .about-hero {
    padding: calc(var(--spacing-xl) + 4rem) 0 var(--spacing-lg);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .about-hero::before {
    content: "";
    position: absolute;
    top: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 800px;
    background: radial-gradient(
      circle,
      rgba(201, 169, 97, 0.1) 0%,
      transparent 60%
    );
    filter: blur(100px);
    pointer-events: none;
  }

  .section-subtitle {
    display: inline-block;
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--gold-primary);
    margin-bottom: 1.5rem;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.5rem 1.5rem;
    background: linear-gradient(
      135deg,
      rgba(201, 169, 97, 0.1),
      rgba(201, 169, 97, 0.05)
    );
    border: 1px solid rgba(201, 169, 97, 0.2);
    border-radius: 30px;
    visibility: hidden;
  }

  .about-title {
    color: var(--text-primary);
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .text-gold {
    background: linear-gradient(
      135deg,
      var(--gold-primary),
      var(--gold-secondary)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-style: italic;
    font-weight: 600;
  }

  .about-tagline {
    font-family: var(--font-body);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--text-muted);
    visibility: hidden;
  }

  /* Bio section */
  .about-bio {
    padding: var(--spacing-lg) 0;
  }

  .about-bio-container {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: var(--spacing-lg);
    align-items: start;
  }

  .about-image-col {
    position: sticky;
    top: 120px;
  }

  .about-image-wrapper {
    position: relative;
  }

  .about-image-reveal {
    overflow: hidden;
    border-radius: var(--radius-lg);
    will-change: clip-path;
    box-shadow:
      0 0 0 1px rgba(201, 169, 97, 0.2),
      0 30px 60px rgba(0, 0, 0, 0.6),
      0 0 80px rgba(201, 169, 97, 0.15);
  }

  .about-image-reveal img {
    width: 100%;
    height: auto;
    display: block;
    filter: grayscale(15%) contrast(105%);
    transition: filter var(--transition-premium);
  }

  .about-image-reveal:hover img {
    filter: grayscale(0%) contrast(100%);
  }

  .about-image-caption {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 2px;
    text-align: center;
    margin-top: 1rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .about-paragraph {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.9;
    font-weight: 300;
    margin-bottom: 2rem;
    visibility: hidden;
  }

  /* Timeline */
  .about-timeline {
    padding: var(--spacing-lg) 0;
    background: linear-gradient(
      to bottom,
      var(--bg-primary),
      var(--bg-secondary)
    );
  }

  .timeline-title {
    text-align: center;
    margin-bottom: var(--spacing-lg);
    color: var(--text-primary);
  }

  .timeline-track {
    position: relative;
    max-width: 700px;
    margin: 0 auto;
    padding-left: 3rem;
  }

  .timeline-line {
    position: absolute;
    left: 0.5rem;
    top: 0;
    bottom: 0;
    width: 2px;
    background: rgba(201, 169, 97, 0.1);
    border-radius: 2px;
  }

  .timeline-line-fill {
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      var(--gold-primary),
      var(--gold-secondary)
    );
    transform-origin: top center;
    border-radius: 2px;
  }

  .timeline-item {
    position: relative;
    padding-bottom: 3rem;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-dot {
    position: absolute;
    left: -2.65rem;
    top: 0.3rem;
    width: 10px;
    height: 10px;
    background: var(--gold-primary);
    border-radius: 50%;
    box-shadow: 0 0 15px rgba(201, 169, 97, 0.4);
    visibility: hidden;
  }

  .timeline-year {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--gold-primary);
    margin-bottom: 0.3rem;
    letter-spacing: 1px;
    visibility: hidden;
  }

  .timeline-text {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.7;
    font-weight: 300;
    margin: 0;
    visibility: hidden;
  }

  /* CTA */
  .about-cta {
    padding: var(--spacing-lg) 0;
  }

  .about-cta-inner {
    text-align: center;
    padding: 3rem;
    border-radius: var(--radius-lg);
    background: linear-gradient(
      135deg,
      rgba(201, 169, 97, 0.06),
      rgba(201, 169, 97, 0.02)
    );
    border: 1px solid rgba(201, 169, 97, 0.1);
    visibility: hidden;
  }

  .about-cta-text {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    color: var(--text-primary);
    margin-bottom: 2rem;
  }

  .about-cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 900px) {
    .about-bio-container {
      grid-template-columns: 1fr;
      gap: var(--spacing-md);
    }

    .about-image-col {
      position: static;
      max-width: 400px;
      margin: 0 auto;
    }

    .timeline-track {
      padding-left: 2.5rem;
    }

    .timeline-dot {
      left: -2.15rem;
    }

    .about-cta-buttons {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
